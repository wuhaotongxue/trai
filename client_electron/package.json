{
  "name": "trai",
  "version": "0.1.24",
  "description": "TRAI 桌面客户端 (Electron)",
  "main": "dist/main/index.js",
  "author": "wuhao",
  "license": "ISC",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:version": "node build_with_version.js",
    "build:only": "vite build",
    "preview": "electron .",
    "type-check": "tsc --noEmit",
    "publish": "node publish.js",
    "publish:local": "set TRAI_API_URL=http://127.0.0.1:5666 && node publish.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.1.7",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "react-window": "^2.2.7",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.wuhao.trai",
    "productName": "TRAI",
    "directories": {
      "output": "release"
    },
    "icon": "public/kity.ico",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/kity_16.ico",
        "to": "kity_16.ico"
      },
      {
        "from": "public/kity_256.ico",
        "to": "kity_256.ico"
      }
    ],
    "win": {
      "icon": "public/kity.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TRAI",
      "uninstallDisplayName": "卸载 TRAI",
      "deleteAppDataOnUninstall": true,
      "installerIcon": "public/kity.ico",
      "uninstallerIcon": "public/kity.ico",
      "installerHeaderIcon": "public/kity.ico"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
