# ============================================================
# TRAI 项目忽略文件配置
# 文件名: .gitignore
# 作者: wuhao
# 日期: 2026_04_09_16:05:36
# 描述: 定义版本控制中需要忽略的文件和目录
# ============================================================

# 日志文件
logs/
*.log

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 环境变量（敏感信息）
.env
.env.local
.env.*.local

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 临时上传目录
uploads/

# 前端依赖与构建产物
frontend_next/node_modules/
frontend_next/.next/
frontend_next/out/
frontend_next/build/
frontend_next/.vercel/
frontend_next/*.tsbuildinfo
frontend_next/next-env.d.ts
frontend_next/coverage/
frontend_next/.pnp
frontend_next/.pnp.*

# 桌面客户端依赖与构建产物
client_electron/node_modules/
client_electron/dist/
client_electron/release/
client_electron/out/
client_electron/.vite/
client_electron/*.tsbuildinfo
client_electron/coverage/

# 包管理器日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# misc
.DS_Store
*.pem
