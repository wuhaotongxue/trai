# ============================================================
# TRAI 项目临时文件规范
# 文件名: .gitignore
# 作者: wuhao
# 日期: 2026_04_24_22:30:00
# 描述: 临时文件管理规范
# ============================================================

# 临时修复文件 (fix_)
*/fix_files/
fix_files/
fix_*.py
fix_*.ts
fix_*.tsx
fix_*.jsx

# 检查脚本 (check_)
*/check_files/
check_files/
check_*.py
check_*.ts
check_*.tsx

# 日志文件
logs/
*.log

# Python 缓存
__pycache__/
*.py[cod]
*.class
*.so

# 环境变量配置文件
.env
.env.local
.env.*.local
# env/ 目录下所有文件（包含敏感配置，全部忽略）
env/
# env_example/ 目录作为备份示例（敏感信息已清理，可提交）
!env_example/

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 临时上传目录
uploads/

# 本地开发数据库
backend/.local_dev.sqlite3

# 前端构建产物和依赖
frontend_next/node_modules/
frontend_next/.next/
frontend_next/out/
frontend_next/build/
frontend_next/.vercel/
frontend_next/*.tsbuildinfo
frontend_next/next-env.d.ts
frontend_next/coverage/
frontend_next/.pnp
frontend_next/.pnp.*

# Electron 构建产物和依赖
client_electron/node_modules/
client_electron/dist/
client_electron/release/
client_electron/release*/
client_electron/trai_*/
client_electron/out/
client_electron/.vite/
client_electron/*.tsbuildinfo
client_electron/coverage/

# 包管理器日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 单元测试和临时脚本
check_comments.py
test_*.py
*test*.py
!backend/scripts/*test.py
backend/scripts/local_executor_test.py
*.test.js
*.test.ts
*.spec.js
*.spec.ts
tmp/
temp/
*.tmp
*.bak

# 大文件 (不包括 git-hooks 使用的)
*.mp4
*.zip
*.tar.gz
*.iso
*.pth
*.bin
*.pt
*.onnx

# 未使用的旧项目
client_pyqt6/

# misc
.DS_Store
*.pem
接口说明.md
.codebuddy/
.codebuddy/
*.sql