# ============================================================
# TRAI 项目忽略文件配置
# 文件名: .gitignore
# 作者: wuhao
# 日期: 2026_04_09_16:05:36
# 描述: 定义版本控制中需要忽略的文件和目录
# ============================================================

# 日志文件
logs/
*.log

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 环境变量（敏感信息）
.env
.env.local
.env.*.local

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 临时上传目录
uploads/