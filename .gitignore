# ============================================================
# TRAI 项目忽略文件配置
# 文件名: .gitignore
# 作者: wuhao
# 日期: 2026_04_09_16:05:36
# 描述: 定义版本控制中需要忽略的文件和目录
# ============================================================

# 日志文件
logs/
*.log

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 环境变量（敏感信息）
.env
.env.local
.env.*.local

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 临时上传目录
uploads/

# 后端本地开发数据库
backend/.local_dev.sqlite3

# 前端依赖与构建产物
frontend_next/node_modules/
frontend_next/.next/
frontend_next/out/
frontend_next/build/
frontend_next/.vercel/
frontend_next/*.tsbuildinfo
frontend_next/next-env.d.ts
frontend_next/coverage/
frontend_next/.pnp
frontend_next/.pnp.*

# 桌面客户端依赖与构建产物
client_electron/node_modules/
client_electron/dist/
client_electron/release/
client_electron/out/
client_electron/.vite/
client_electron/*.tsbuildinfo
client_electron/coverage/

# 包管理器日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 测试与临时脚本文件
check_comments.py
test_*.py
*test*.py
*.test.js
*.test.ts
*.spec.js
*.spec.ts
tmp/
temp/
*.tmp
*.bak

# 大文件拦截 (建议配合 git-hooks 使用)
# 虽然 gitignore 不能按大小过滤, 但可以拦截常见的大型模型/视频/压缩包
*.mp4
*.zip
*.tar.gz
*.iso
*.pth
*.bin
*.pt
*.onnx

# misc
.DS_Store
*.pem
