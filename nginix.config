server {
    listen 80;
    server_name trai.com;
    return 301 https://$host$request_uri;
}

server {
    # 暂时移除 http2 以排除协议干扰
    # 修复 400 The plain HTTP request was sent to HTTPS port
    # 原因: 前置 WAF/网关 (10.0.0.1) 进行了 SSL 卸载，并以 HTTP 协议转发到后端的 443 端口
    # 因此，Nginx 必须在 443 端口上监听 HTTP，而不是 HTTPS
    listen 443;
    server_name trai.com;
    index index.html index.htm default.html;
    root /home/code/trai/frontend_next/out;
    
    # 包含其他配置 (如有必要保留)
    include /www/server/panel/vhost/nginx/extension/192.168.100.119/*.conf;

    # 前端路由支持
    location / {
        try_files $uri $uri/ /index.html;
    }
    
    # 静态资源缓存
    location ~* \.(js|css|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires max;
        access_log off;
    }
    
    # 静态资源与版本更新代理 (最高优先级，直接转发)
    location ^~ /static/ { 
        proxy_pass http://192.168.1.1:5666; 
        proxy_set_header Host $host; 
        proxy_set_header X-Real-IP $remote_addr; 
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; 
        proxy_set_header X-Forwarded-Proto $scheme; 
        
        # 禁用缓存以保证能获取到最新 version.json 
        add_header Cache-Control "no-store, no-cache, must-revalidate"; 
    }
    
    # API代理转发到后端服务 (HTTP 接口) 
    location /api_trai/ { 
        proxy_pass http://192.168.1.1:5666; 
        proxy_set_header Host $host; 
        proxy_set_header X-Real-IP $remote_addr; 
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; 
        proxy_set_header X-Forwarded-Proto $scheme; 
        proxy_connect_timeout 60s; 
        proxy_send_timeout 60s; 
        proxy_read_timeout 60s; 
    } 
    
    # WebSocket 语音实时录音 (HTTPS 需升级为 wss)
    location ~ ^/api_trai/v1/speech/ws/(transcribe|xunfei/transcribe) {
        proxy_pass http://192.168.1.1:5666;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }
    
    # S3 存储桶代理 (终极净化版 - 提升优先级)
    # 使用 ^~ 防止被静态资源正则(ico/jpg等)拦截
    location ^~ /trai/ {
        # 直接透传到 S3 网关
        proxy_pass http://192.168.1.1:12001;
        
        # 显式指定 Host 为 Upstream 的 IP:Port
        # 避免 S3 网关因为域名 Host 而触发 HTTPS 重定向或校验
        proxy_set_header Host 192.168.0.1:12001;
        
        # 强制 HTTP/1.1 长连接
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        
        # 清除可能导致 Upstream 误判协议的 Header
        proxy_set_header X-Forwarded-Proto "";
        proxy_set_header X-Forwarded-Ssl "";
        
        # 传递真实 IP (用于审计日志)
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        
        # 大文件/大头支持
        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;
        proxy_temp_file_write_size 512k;
        
        # 禁用 Chunked 传输 (某些对象存储不支持)
        chunked_transfer_encoding off;
        
        # 隐藏 S3 特有响应头
        proxy_hide_header x-amz-id-2;
        proxy_hide_header x-amz-request-id;
    }
    
    # SSL证书配置 (注释掉，因为WAF已做SSL卸载)
    # ssl_certificate    /www/server/panel/vhost/cert/192.168.100.119/fullchain.pem;
    # ssl_certificate_key    /www/server/panel/vhost/cert/192.168.100.119/privkey.pem;
    # ssl_protocols TLSv1.2 TLSv1.3;
    # ssl_ciphers EECDH+CHACHA20:EECDH+AES128:RSA+AES128:EECDH+AES256:RSA+AES256:!MD5;
    # ssl_prefer_server_ciphers on;
    # ssl_session_tickets on;
    # ssl_session_cache shared:SSL:10m;
    # ssl_session_timeout 10m;
    # add_header Strict-Transport-Security "max-age=31536000";
    
    # HTTP/3 支持 (注释掉，因为没有SSL)
    # add_header Alt-Svc 'quic=":443"; h3=":443"; h3-29=":443"; h3-27=":443";h3-25=":443"; h3-T050=":443"; h3-Q050=":443";h3-Q049=":443";h3-Q048=":443"; h3-Q046=":443"; h3-Q043=":443"';
    
    # 错误页配置
    error_page 404 /index.html;
    
    # 禁止访问的敏感文件/目录
    location ~ ^/(\.user.ini|\.htaccess|\.git|\.env|\.svn|\.project|LICENSE|README.md) {
        return 404;
    }
    
    # 下载目录配置
    location /download/ {
        alias /www/wwwroot/download/;
        add_header Access-Control-Allow-Origin "*";
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
        add_header Access-Control-Allow-Headers "Content-Type";
        autoindex on;
    }
    
    # SSL证书验证目录
    location ~ \.well-known {
        allow all;
        if ($uri ~ "^/\.well-known/.*\.(php|jsp|py|js|css|lua|ts|go|zip|tar\.gz|rar|7z|sql|bak)$") {
            return 403;
        }
    }
    
    # 日志配置
    access_log  /www/wwwlogs/192.168.1.1.log;
    error_log  /www/wwwlogs/192.168.1.1.error.log;
}
