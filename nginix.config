server
{
    listen 80;
    server_name ai.tuoren.com;
    return 301 https://$host$request_uri;
}

server
{
    listen 443;
    server_name ai.tuoren.com;
    index index.html;
    root /home/code/trai/frontend/dist;
    include /www/server/panel/vhost/nginx/extension/ai.tuoren.com/*.conf;

    # ---------- API 代理到后端 (192.168.100.119:5777) ----------
    location /api_trai {
        proxy_pass http://192.168.100.119:5777;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_read_timeout 120s;
    }

    # WebSocket 代理（如有语音功能）
    location /ws_trai {
        proxy_pass http://192.168.100.119:5777;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400s;
    }

    # ---------- S3 备份文件代理（放在 location / 之前）----------
    # 说明：
    # - 外网访问路径使用 /trai/ 前缀（例如 /trai/diti-backup/<object>）
    # - diti-backup 这个桶仍然保持独立转发规则
    location ^~ /trai/diti-backup/ {
        proxy_pass http://192.168.0.190:12001/diti-backup/;
        
        proxy_set_header Host 192.168.0.190:12001;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        
        proxy_buffering off;
        proxy_http_version 1.1;
        proxy_connect_timeout 300s;
        proxy_read_timeout 300s;
        client_max_body_size 0;
        proxy_set_header Range $http_range;
        proxy_set_header If-Range $http_if_range;
        add_header Accept-Ranges bytes always;
        
        proxy_intercept_errors on;
        error_page 404 = @s3_404;
    }

    location ^~ /trai/ {
        # Reverse proxy to S3. Keep the original /trai/... URI so the
        # upstream path stays consistent with the path used for presigning.
        proxy_pass http://192.168.0.190:12001;
        
        proxy_set_header Host 192.168.0.190:12001;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # 音乐、视频、图片等大文件访问优化
        proxy_buffering off;
        proxy_http_version 1.1;
        proxy_connect_timeout 300s;
        proxy_read_timeout 300s;
        client_max_body_size 0;
        proxy_set_header Range $http_range;
        proxy_set_header If-Range $http_if_range;
        add_header Accept-Ranges bytes always;
        
        # S3 不存在时直接返回 404，不走 SPA
        proxy_intercept_errors on;
        error_page 404 = @s3_404;
    }
    
    location @s3_404 {
        return 404;
    }

    # ---------- 前端静态文件（取消注释！）----------
    location / {
        try_files $uri $uri/ /index.html;
    }

    # JS / CSS 缓存
    location ~* \.(js|css)$ {
        expires 12h;
        access_log off;
        add_header Cache-Control "public, no-transform";
    }

    # 图片缓存
    location ~* \.(gif|jpg|jpeg|png|bmp|swf|webp|ico|svg)$ {
        expires 30d;
        access_log off;
        add_header Cache-Control "public, no-transform";
    }

    # ---------- 安全相关 ----------
    # 禁止访问敏感文件
    location ~* (\.env|\.git|\.svn|LICENSE|README|\.log|\.sql|\.bak|\.htaccess|\.user.ini|Dockerfile|docker-compose) {
        return 404;
    }

    # 禁止访问隐藏目录
    location ~ /\. {
        return 404;
    }

    # 日志（如不需要可关闭）
    access_log /www/wwwlogs/ai.tuoren.com.log;
    error_log  /www/wwwlogs/ai.tuoren.com.error.log;
}
