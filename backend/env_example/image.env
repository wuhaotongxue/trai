# ============================================================
# TRAI Backend Environment Configuration
# 文件名: image.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 图像生成配置
# ============================================================

# ============================================================
# 图像生成配置
# ============================================================

# 图像生成服务提供商
# local: 本地 ModelScope Z-Image-Turbo (默认,使用已下载模型)
# dashscope: DashScope 云端 API (wanx-v1 等)
# openai: OpenAI DALL-E
# api: 自定义 API 模式
IMAGE_PROVIDER=local

# 本地模型路径 (已下载 Tongyi-MAI/Z-Image-Turbo)
MODELSCOPE_IMAGE_MODEL_PATH=/home/qyjgylc_whf/.cache/modelscope/hub/models/Tongyi-MAI/Z-Image-Turbo

# 魔塔社区图像生成模型
# FLUX.1-dev: 高质量图像生成
MODELSCOPE_IMAGE_MODEL=wanx-v1

# 生成迭代步数（影响质量和速度）
# 数值越大质量越高，速度越慢
# 建议值: 20-50
MODELSCOPE_IMAGE_STEPS=30

# 生成图像宽度（像素）
MODELSCOPE_IMAGE_WIDTH=1024

# 生成图像高度（像素）
MODELSCOPE_IMAGE_HEIGHT=1024

# 随机种子（-1 表示随机）
# 使用相同种子可以获得可复现的结果
MODELSCOPE_IMAGE_SEED=-1
