# ============================================================
# TRAI Backend Environment Configuration
# 文件名: email.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 邮件配置
# ============================================================

# ============================================================
# 邮件配置
# ============================================================

# 是否启用邮件功能
# true: 可以发送邮件
# false: 禁用邮件
EMAIL_ENABLED=false

# ============================================================
# SMTP 标准邮件配置
# ============================================================

# SMTP 服务器地址
EMAIL_SMTP_HOST=smtp.example.com

# SMTP 端口
# 25: 标准（常被防火墙阻止）
# 465: SMTP over SSL
# 587: STARTTLS（推荐）
EMAIL_SMTP_PORT=587

# SMTP 用户名
EMAIL_SMTP_USER=noreply@example.com

# SMTP 密码
# 【重要】生产环境必须使用强密码
EMAIL_SMTP_PASSWORD=

# 是否使用 STARTTLS
# true: 使用 587 端口
# false: 使用 465 端口
EMAIL_SMTP_USE_TLS=true

# 是否使用 SSL
# true: 使用 465 端口
# false: 不使用
EMAIL_SMTP_USE_SSL=false

# SMTP 连接超时（秒）
EMAIL_SMTP_TIMEOUT=30

# 发件人显示名称
EMAIL_SMTP_FROM_NAME=TRAI System

# 发件人邮箱地址
EMAIL_SMTP_FROM_ADDRESS=noreply@example.com

# ============================================================
# 企业微信邮件配置
# ============================================================

# 是否启用企业微信邮件
EMAIL_WECOM_ENABLED=false

# 企业 ID
EMAIL_WECOM_CORP_ID=wwxxxxxxxxxxxxxx

# 应用 Secret
EMAIL_WECOM_SECRET=

# 发件人名称
EMAIL_WECOM_FROM_NAME=TRAI System

# ============================================================
# 钉钉邮件配置
# ============================================================

# 是否启用钉钉邮件
EMAIL_DINGTALK_ENABLED=false

# Access Key ID
EMAIL_DINGTALK_ACCESS_KEY=

# Access Key Secret
EMAIL_DINGTALK_ACCESS_SECRET=

# 发件人名称
EMAIL_DINGTALK_FROM_NAME=TRAI System

# ============================================================
# 飞书邮件配置
# ============================================================

# 是否启用飞书邮件
EMAIL_FEISHU_ENABLED=false

# App ID
EMAIL_FEISHU_APP_ID=your-feishu-app-id

# App Secret
EMAIL_FEISHU_APP_SECRET=

# 发件人名称
EMAIL_FEISHU_FROM_NAME=TRAI System

# ============================================================
# SendGrid 邮件配置
# ============================================================

# 是否启用 SendGrid
EMAIL_SENDGRID_ENABLED=false

# SendGrid API Key
EMAIL_SENDGRID_API_KEY=

# 发件人名称
EMAIL_SENDGRID_FROM_NAME=TRAI System

# 发件人地址
EMAIL_SENDGRID_FROM_ADDRESS=noreply@example.com

# ============================================================
# 阿里云邮件推送配置
# ============================================================

# 是否启用阿里云邮件推送
EMAIL_ALIYUN_ENABLED=false

# Access Key ID
EMAIL_ALIYUN_ACCESS_KEY=

# Access Key Secret
EMAIL_ALIYUN_ACCESS_SECRET=

# 发件账号
EMAIL_ALIYUN_ACCOUNT_NAME=noreply@example.com

# 发件人名称
EMAIL_ALIYUN_FROM_NAME=TRAI System

# ============================================================
# 邮件通用配置
# ============================================================

# 默认邮件发送渠道
# 用于未指定渠道时
EMAIL_DEFAULT_PROVIDER=smtp

# 邮件发送超时（秒）
EMAIL_TIMEOUT=30

# 单封邮件最大收件人数量
# 超过此数量需要分批发送
EMAIL_MAX_RECIPIENTS=50

# 每日发送上限
# 用于防止滥用
EMAIL_DAILY_LIMIT=1000

# 是否启用 HTML 模板
# true: 支持 HTML 格式邮件
# false: 仅支持纯文本
EMAIL_HTML_ENABLED=true

# ============================================================
# 邮件场景配置
# ============================================================

# 欢迎邮件发送渠道（逗号分隔）
# 格式: 渠道1,渠道2
EMAIL_SCENE_WELCOME_PROVIDERS=smtp

# 密码重置邮件发送渠道
EMAIL_SCENE_RESET_PASSWORD_PROVIDERS=smtp

# 会议邀请邮件发送渠道
EMAIL_SCENE_MEETING_INVITE_PROVIDERS=wecom,smtp

# AI 任务通知邮件发送渠道
EMAIL_SCENE_AI_TASK_PROVIDERS=wecom