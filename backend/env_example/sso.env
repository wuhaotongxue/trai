# ============================================================
# TRAI Backend Environment Configuration
# 文件名: sso.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: SSO 集成配置（企业微信、钉钉、飞书、GitHub、GitLab）
# ============================================================

# ============================================================
# 企业微信 SSO 配置
# ============================================================

# 是否启用企业微信
# true: 启用企业微信登录和集成
# false: 禁用
WECOM_ENABLED=true

# 企业 ID（用于标识企业）
# 在企业微信管理后台 -> 我的企业 查看
WECOM_CORP_ID=your-corp-id

# 应用 Agent ID
# 在企业微信管理后台 -> 应用管理 查看
WECOM_AGENT_ID=1000000

# 应用 Secret
# 【重要】生产环境必须保护，不要暴露在前端
WECOM_SECRET=your-wecom-secret

# 回调验证 Token
# 用于验证回调请求来源
# 建议使用随机字符串，至少 32 字符
WECOM_CALLBACK_TOKEN=your-callback-token

# 回调 AES 密钥
# 用于加密回调消息
# 必须为 43 位字符
WECOM_CALLBACK_AES_KEY=abcdefghijklmnopqrstuvwxyz1234567890ABC

# OAuth 回调地址
# 用户授权后跳转回本系统的地址
# 必须与企业在企业微信后台配置的一致
WECOM_REDIRECT_URI=https://your-domain.com/api_trai/v1/auth/wecom/callback

# 后端公开访问的地址，必须与企业微信后台配置的域名一致
BACKEND_PUBLIC_URL=https://your-domain.com

# 前端公开访问地址（企业微信登录成功后跳转）
FRONTEND_URL=https://your-domain.com

# 企业微信 API 基础地址
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com

# API 请求超时时间（秒）
WECOM_API_TIMEOUT=30

# API 最大重试次数
WECOM_API_MAX_RETRIES=3

# OAuth 授权范围
# snsapi_base: 仅获取用户 UserID
# snsapi_userinfo: 获取用户姓名、头像等信息
WECOM_LOGIN_SCOPE=snsapi_base

# 登录状态有效期（秒）
# 用户在授权页面停留超过此时间需重新授权
WECOM_LOGIN_STATE_EXPIRE=600

# 是否自动绑定已有账号
# true: 企业微信用户自动绑定同用户名/邮箱的已有账号
# false: 必须手动绑定或注册新账号
WECOM_LOGIN_AUTO_BIND=false

# ============================================================
# 企业微信用户同步配置
# ============================================================

# 是否启用用户同步
# true: 定期从企业微信同步用户到本地
# false: 不同步
WECOM_USER_SYNC_ENABLED=true

# 同步方式
# full: 全量同步（每次同步所有用户）
# incremental: 增量同步（仅同步变更的用户）
# full_on_first: 首次全量，后续增量
WECOM_USER_SYNC_MODE=incremental

# 同步周期（Cron 表达式）
# 0 0 * * *: 每天凌晨
# 0 */4 * * *: 每 4 小时
# 0 */6 * * *: 每 6 小时
# 参考: https://crontab.guru/
WECOM_USER_SYNC_CRON=0 0 * * *

# 首次同步是否自动执行
# true: 服务启动时自动执行首次同步
# false: 手动触发首次同步
WECOM_USER_SYNC_AUTO_FIRST=true

# 要同步的部门 ID 列表（逗号分隔）
# 空: 同步全部部门
# 示例: 1,2,3: 只同步这 3 个部门
WECOM_USER_SYNC_DEPARTMENT_IDS=

# 是否包含离职员工
# true: 同步已离职员工（标记为禁用）
# false: 不同步离职员工
WECOM_USER_SYNC_INCLUDE_INACTIVE=false

# 离职员工处理方式
# disable: 禁用账号（保留数据）
# delete: 删除账号
# freeze: 冻结账号
WECOM_USER_SYNC_INACTIVE_ACTION=disable

# 用户字段映射配置
# 定义企业微信字段与本地字段的对应关系
WECOM_USER_SYNC_FIELD_USERID=userid
WECOM_USER_SYNC_FIELD_NAME=name
WECOM_USER_SYNC_FIELD_DEPARTMENT=department
WECOM_USER_SYNC_FIELD_POSITION=position
WECOM_USER_SYNC_FIELD_MOBILE=mobile
WECOM_USER_SYNC_FIELD_EMAIL=email
WECOM_USER_SYNC_FIELD_AVATAR=avatar

# 是否自动创建部门
# true: 企业微信的部门在本地自动创建
# false: 部门必须手动创建
WECOM_USER_SYNC_AUTO_CREATE_DEPT=true

# 同步冲突处理策略
# wecom: 以企业微信数据为准
# local: 以本地数据为准（保留本地修改）
# merge: 合并策略（取两者的并集）
WECOM_USER_SYNC_CONFLICT_STRATEGY=wecom

# 是否同步用户头像
# true: 下载并保存用户头像
# false: 不同步头像
WECOM_USER_SYNC_AVATAR=true

# 头像下载超时（秒）
WECOM_USER_SYNC_AVATAR_TIMEOUT=30

# 同步失败重试次数
WECOM_USER_SYNC_MAX_RETRIES=3

# 同步失败重试间隔（秒）
WECOM_USER_SYNC_RETRY_DELAY=60

# 同步锁过期时间（秒）
# 防止多个进程同时同步
WECOM_USER_SYNC_LOCK_EXPIRE=3600

# 是否记录同步详细日志
# true: 记录每次同步的详细信息
# false: 只记录概要
WECOM_USER_SYNC_DETAILED_LOG=false

# 同步超时时间（秒）
# 超过此时间未完成则中断同步
WECOM_USER_SYNC_TIMEOUT=1800

# 是否启用同步事件通知
# true: 同步完成后发送通知
# false: 不发送
WECOM_USER_SYNC_NOTIFY=false

# ============================================================
# 钉钉 SSO 配置
# ============================================================

# 是否启用钉钉
# true: 启用钉钉登录和集成
# false: 禁用
DINGTALK_ENABLED=false

# 钉钉应用 App ID
DINGTALK_APP_ID=your-dingtalk-app-id

# 钉钉应用 App Secret
# 【重要】生产环境必须保护
DINGTALK_APP_SECRET=your-dingtalk-app-secret

# 回调验证 Token
DINGTALK_CALLBACK_TOKEN=

# 回调 AES 密钥
DINGTALK_CALLBACK_AES_KEY=

# OAuth 回调地址
DINGTALK_REDIRECT_URI=http://localhost:5666/auth/dingtalk/callback

# 钉钉 API 基础地址
DINGTALK_API_BASE_URL=https://api.dingtalk.com

# API 请求超时时间（秒）
DINGTALK_API_TIMEOUT=30

# OAuth 授权范围
# corpid: 仅获取企业 ID
# userid: 获取用户 ID
DINGTALK_LOGIN_SCOPE=corpid

# 是否自动绑定已有账号
DINGTALK_LOGIN_AUTO_BIND=false

# ============================================================
# 飞书 SSO 配置
# ============================================================

# 是否启用飞书
# true: 启用飞书登录和集成
# false: 禁用
FEISHU_ENABLED=false

# 飞书应用 App ID
FEISHU_APP_ID=your-feishu-app-id

# 飞书应用 App Secret
# 【重要】生产环境必须保护
FEISHU_APP_SECRET=your-feishu-app-secret

# 回调验证 Token
FEISHU_CALLBACK_TOKEN=

# 回调 AES 密钥
FEISHU_CALLBACK_AES_KEY=

# OAuth 回调地址
FEISHU_REDIRECT_URI=http://localhost:5666/auth/feishu/callback

# 飞书 API 基础地址
FEISHU_API_BASE_URL=https://open.feishu.cn

# API 请求超时时间（秒）
FEISHU_API_TIMEOUT=30

# OAuth 授权范围
# tenant: 获取租户信息
# user: 获取用户信息
FEISHU_LOGIN_SCOPE=tenant

# 是否自动绑定已有账号
FEISHU_LOGIN_AUTO_BIND=false

# ============================================================
# GitHub OAuth 登录配置
# ============================================================

# 是否启用 GitHub OAuth 登录
# true: 启用 GitHub 登录和集成
# false: 禁用
GITHUB_OAUTH_ENABLED=false

# GitHub OAuth 应用 Client ID
# 在 https://github.com/settings/developers 创建应用后获取
GITHUB_CLIENT_ID=

# GitHub OAuth 应用 Client Secret
GITHUB_CLIENT_SECRET=

# OAuth 回调地址
GITHUB_REDIRECT_URI=http://localhost:5666/api/v1/auth/github/callback

# OAuth 请求超时时间（秒）
GITHUB_TIMEOUT=10

# 是否自动绑定已有账号
# true: GitHub 用户自动绑定同用户名/邮箱的已有账号
# false: 必须手动绑定或注册新账号
GITHUB_AUTO_BIND=false

# ============================================================
# GitLab OAuth 登录配置
# ============================================================

# 是否启用 GitLab OAuth 登录
# true: 启用 GitLab 登录和集成
# false: 禁用
GITLAB_OAUTH_ENABLED=false

# GitLab OAuth 应用 Application ID
# 在 GitLab 实例的 Applications 设置中创建
GITLAB_APPLICATION_ID=

# GitLab OAuth 应用 Secret
GITLAB_SECRET=

# GitLab 实例地址（自建 GitLab 时填写）
# 公开 GitLab: https://gitlab.com
GITLAB_BASE_URL=https://gitlab.com

# OAuth 回调地址
GITLAB_REDIRECT_URI=http://localhost:5666/api/v1/auth/gitlab/callback

# OAuth 请求超时时间（秒）
GITLAB_TIMEOUT=10

# 是否自动绑定已有账号
# true: GitLab 用户自动绑定同用户名/邮箱的已有账号
# false: 必须手动绑定或注册新账号
GITLAB_AUTO_BIND=false