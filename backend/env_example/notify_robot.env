# ============================================================
# TRAI Backend Environment Configuration
# 文件名: notify_robot.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 通知机器人配置
# ============================================================

# ============================================================
# 通知机器人配置
# ============================================================

# 是否启用通知功能
# true: 可以发送通知
# false: 禁用通知
NOTIFY_ENABLED=true

# ============================================================
# 企业微信群机器人配置
# ============================================================

# 是否启用企业微信群机器人
NOTIFY_WECOM_ENABLED=true

# Webhook 地址
# 在企业微信群设置中获取
NOTIFY_WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-webhook-key

# 数据智能技术研究所
DATA_INTELLIGENCE_INSTITUTE_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-webhook-key

# 请求超时（秒）
NOTIFY_WECOM_TIMEOUT=10

# 最大重试次数
NOTIFY_WECOM_MAX_RETRIES=3

# 重试间隔（秒）
NOTIFY_WECOM_RETRY_DELAY=1

# ============================================================
# 钉钉群机器人配置
# ============================================================

# 是否启用钉钉群机器人
NOTIFY_DINGTALK_ENABLED=false

# Webhook 地址
NOTIFY_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token

# 请求超时（秒）
NOTIFY_DINGTALK_TIMEOUT=10

# 最大重试次数
NOTIFY_DINGTALK_MAX_RETRIES=3

# 加签密钥（可选）
# 启用加签时填写，用于签名验证
NOTIFY_DINGTALK_SECRET=

# ============================================================
# 飞书群机器人配置
# ============================================================

# 是否启用飞书群机器人
NOTIFY_FEISHU_ENABLED=false

# Webhook 地址
NOTIFY_FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# 请求超时（秒）
NOTIFY_FEISHU_TIMEOUT=10

# 最大重试次数
NOTIFY_FEISHU_MAX_RETRIES=3

# ============================================================
# QQ 群机器人配置
# ============================================================

# 是否启用 QQ 群机器人
NOTIFY_QQ_ENABLED=false

# WebSocket 网关地址
NOTIFY_QQ_WEBHOOK=https://api.sgroup.qq.com/gateway/bot

# 机器人 Token
NOTIFY_QQ_BOT_TOKEN=

# 机器人 Secret
NOTIFY_QQ_BOT_SECRET=

# 请求超时（秒）
NOTIFY_QQ_TIMEOUT=10

# 最大重试次数
NOTIFY_QQ_MAX_RETRIES=3

# ============================================================
# 通知通用配置
# ============================================================

# 通知冷却时间（秒）
# 同一类型通知在此时段内不重复发送
NOTIFY_COOLDOWN_SECONDS=300

# 默认通知渠道
# 未指定渠道时使用
NOTIFY_DEFAULT_CHANNEL=wecom

# ============================================================
# 通知场景配置
# ============================================================

# AI 任务完成通知渠道
NOTIFY_SCENE_1_CHANNELS=wecom

# 会议提醒通知渠道
NOTIFY_SCENE_2_CHANNELS=wecom,dingtalk

# 系统告警通知渠道
NOTIFY_SCENE_3_CHANNELS=wecom,dingtalk,feishu

# 用户审计通知渠道
NOTIFY_SCENE_4_CHANNELS=wecom

# ============================================================
# Webhook 配置
# ============================================================

# 是否启用 Webhook
# true: 支持向外部系统发送事件通知
# false: 禁用
WEBHOOK_ENABLED=false

# Webhook 请求超时时间（秒）
WEBHOOK_TIMEOUT=10

# 最大重试次数
# 发送失败后的重试次数
WEBHOOK_MAX_RETRIES=3

# 重试间隔（秒）
# 每次重试之间的等待时间
WEBHOOK_RETRY_DELAY=5

# Webhook 签名密钥
# 用于生成 HMAC 签名，接收方可以验证消息来源
WEBHOOK_SECRET=

# Webhook 事件类型白名单（逗号分隔）
# 留空表示接收所有事件
# 示例: user.created,user.updated,ai.task.completed
WEBHOOK_EVENT_WHITELIST=

# Webhook 目标地址列表（JSON 数组）
# 示例: ["https://example.com/webhook", "https://ci.example.com/hook"]
WEBHOOK_URLS=[]