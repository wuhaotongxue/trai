# ============================================================
# TRAI Backend Environment Configuration
# 文件名: tracing.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 链路追踪配置
# ============================================================

# ============================================================
# 异常追踪配置
# ============================================================

# 是否启用异常追踪
# true: 启用，收集未处理异常
# false: 禁用
ERROR_TRACKING_ENABLED=true

# 异常追踪服务提供商
# sentry: Sentry（推荐）
# bugsnag: Bugsnag
# custom: 自建服务
ERROR_TRACKING_PROVIDER=sentry

# 异常采样率（0-1）
# 1.0 = 记录所有异常
ERROR_TRACKING_SAMPLE_RATE=1.0

# ============================================================
# Sentry 配置
# ============================================================

# Sentry DSN（Data Source Name）
# 用于连接 Sentry 服务
# 格式: https://xxx@sentry.io/xxx
SENTRY_DSN=

# Sentry 环境名称
# 示例: development, staging, production
SENTRY_ENVIRONMENT=development

# 链路追踪采样率（0-1）
# 0.1 = 10% 的请求会被追踪
SENTRY_TRACES_SAMPLE_RATE=0.1

# 性能分析采样率（0-1）
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================
# APM 配置
# ============================================================

# 是否启用 APM（应用性能监控）
# true: 启用，请求链路追踪
# false: 禁用
APM_ENABLED=false

# APM 服务名称
APM_SERVICE_NAME=trai-backend

# APM 服务地址
# 例如: Elastic APM Server
APM_SERVER_URL=http://localhost:8200

# APM 认证 Token
APM_SECRET_TOKEN=

# ============================================================
# OpenTelemetry 链路追踪配置
# ============================================================

# 是否启用 OpenTelemetry
# true: 启用分布式追踪
# false: 禁用
OTEL_ENABLED=false

# 服务名称
OTEL_SERVICE_NAME=trai-backend

# OTLP 导出器地址
# gRPC: 192.168.100.119:4317
# HTTP: 192.168.100.119:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://192.168.100.119:4317

# 链路采样器类型
# parentbased_traceidratio: 基于父级追踪的采样
# always_on: 全部记录
# always_off: 全部跳过
# ratio: 按比例采样
OTEL_TRACES_SAMPLER=parentbased_traceidratio

# 采样率参数（0-1）
OTEL_TRACES_SAMPLER_ARG=0.1

# ============================================================
# OpenTelemetry 详细配置
# ============================================================

# OTLP 协议
# grpc: gRPC 协议（推荐）
# http/protobuf: HTTP 协议
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# 链路追踪导出端点
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://192.168.100.119:4317

# 指标导出端点
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://192.168.100.119:4317

# 日志导出端点
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://192.168.100.119:4318

# 自定义 Header（认证用）
# 格式: key1=value1,key2=value2
OTEL_EXPORTER_OTLP_HEADERS=

# ============================================================
# 链路追踪详细配置
# ============================================================

# 是否启用链路追踪
OTEL_TRACES_ENABLED=true

# Debug 模式下是否采样
OTEL_TRACES_SAMPLE_ON_DEBUG=false

# 排除追踪的路径（逗号分隔）
# 这些路径不会被追踪
OTEL_TRACES_EXCLUDED_PATHS=/health,/metrics,/docs,/openapi.json

# Span 属性数量限制
OTEL_SPAN_ATTRIBUTE_COUNT_LIMIT=128

# Span 事件数量限制
OTEL_EVENT_ATTRIBUTE_COUNT_LIMIT=128

# Span 链接数量限制
OTEL_LINK_ATTRIBUTE_COUNT_LIMIT=128

# ============================================================
# OpenTelemetry 指标配置
# ============================================================

# 是否启用指标收集
OTEL_METRICS_ENABLED=true

# 指标导出间隔（毫秒）
# 60000 = 1 分钟
OTEL_METRICS_EXPORT_INTERVAL=60000

# ============================================================
# OpenTelemetry 日志配置
# ============================================================

# 是否启用日志集成
OTEL_LOGS_ENABLED=false

# 日志级别
OTEL_LOG_LEVEL=INFO

# ============================================================
# OpenTelemetry Baggage 配置
# ============================================================

# 是否启用 Baggage
# Baggage 用于在链路中传递上下文信息
OTEL_BAGGAGE_ENABLED=true

# Baggage Key 前缀
OTEL_BAGGAGE_PREFIX=trai/

# ============================================================
# 审计日志配置
# ============================================================

# 是否启用审计日志
# true: 记录所有敏感操作
# false: 禁用审计日志
AUDIT_LOG_ENABLED=true

# 审计日志存储渠道
# database: 存入数据库，便于查询分析
# elasticsearch: 存入 ES，适合大规模日志
# file: 存入文件
AUDIT_LOG_CHANNEL=database

# 审计日志保留天数
# 超过此时间的日志将被清理
AUDIT_LOG_RETENTION_DAYS=365

# 是否记录读取操作
# true: SELECT 查询也记录（数据量大）
# false: 仅记录增删改操作
AUDIT_LOG_INCLUDE_READS=false

# 是否记录删除操作
# true: 记录所有删除操作
# false: 不记录
AUDIT_LOG_INCLUDE_DELETES=true

# 需要脱敏的字段名（逗号分隔）
# 这些字段的值在日志中显示为 ****
AUDIT_LOG_MASK_FIELDS=password,token,secret,key,authorization,api_key

# 审计日志批次大小
# 达到此数量后批量写入
AUDIT_LOG_BATCH_SIZE=100

# 审计日志异步写入
# true: 异步写入，不阻塞主流程
# false: 同步写入
AUDIT_LOG_ASYNC=true
