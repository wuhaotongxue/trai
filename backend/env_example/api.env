# ============================================================
# TRAI Backend Environment Configuration
# 文件名: api.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: API 与网关配置
# ============================================================

# ============================================================
# API 配置
# ============================================================

# API URL 前缀，用于版本隔离和路径区分
# 示例: /api/v1 表示 API 第一版本
# 示例: /api/v2 表示 API 第二版本
API_PREFIX=/api_trai/v1

# 允许的 HTTP 请求方法
# 逗号分隔，多种方法可用
# 注意: OPTIONS 是 CORS 预检请求必需
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# API 文档开关（生产环境建议关闭）
# true: 启用 /docs 和 /redoc 文档页面
# false: 关闭文档，减少暴露接口信息
API_DOCS_ENABLED=true

# Swagger 文档页面路径
API_DOCS_URL=/docs

# OpenAPI JSON 规范文件路径
OPENAPI_URL=/openapi.json

# API 版本控制开关
# true: 启用基于 URL 的版本控制（如 /api/v1, /api/v2）
# false: 单一版本
API_VERSIONING_ENABLED=true

# 默认 API 版本，用于未指定版本时的回退
# 建议始终指向最新稳定版本
API_DEFAULT_VERSION=v1

# ============================================================
# API 版本管理增强配置
# ============================================================

# 支持的 API 版本列表（逗号分隔）
# 按版本从旧到新排列，最旧的放最前面
API_SUPPORTED_VERSIONS=v1,v2,v3

# 已废弃的 API 版本（逗号分隔）
# 这些版本会返回 Deprecation 警告头
API_DEPRECATED_VERSIONS=v1

# 废弃版本警告提前天数
# 在此天数内即将废弃的版本会返回额外警告
API_DEPRECATION_WARNING_DAYS=90

# API 版本废弃日期（逗号分隔的日期）
# 格式: v1=2026-12-31,v2=2027-06-30
# 到达日期后该版本将被完全禁用
API_VERSION_SUNSET_SCHEDULE=v1=2026-12-31,v2=2027-06-30

# 废弃版本是否允许新用户注册
# true: 仅已注册用户可继续使用
# false: 完全禁止
API_DEPRECATED_ALLOW_EXISTING=false

# 版本兼容性检查
# true: 校验客户端版本与 API 版本兼容性
# false: 不校验
API_VERSION_CHECK_ENABLED=true

# ============================================================
# CORS 跨域配置
# ============================================================

# 允许跨域请求的来源地址（逗号分隔）
# 【重要】生产环境必须修改为实际域名
# 示例: https://trai.example.com,https://www.trai.com
# 使用 * 允许所有来源（仅建议开发环境使用）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 是否允许跨域请求携带凭证（Cookie、认证头）
# true: 允许，CORS_ORIGINS 不能设为 *
# false: 不允许，更安全但限制某些功能
CORS_ALLOW_CREDENTIALS=true

# 允许的请求头（* 表示全部，允许自定义头需显式列出）
# 示例: Content-Type,Authorization,X-Request-ID
CORS_ALLOW_HEADERS=*

# 允许的 HTTP 方法
CORS_ALLOW_METHODS=*

# 预检请求（OPTIONS）的缓存时间（秒）
# 此时间内浏览器不会重复发送预检请求
# 600 秒 = 10 分钟
CORS_MAX_AGE=600

# ============================================================
# CDN 配置
# ============================================================

# 是否启用 CDN
# true: 静态资源通过 CDN 分发
# false: 使用源站直接服务
CDN_ENABLED=false

# CDN 提供商
# aliyun: 阿里云 CDN
# tencent: 腾讯云 CDN
# aws_cloudfront: AWS CloudFront
# cloudflare: Cloudflare
# custom: 自建 CDN
CDN_PROVIDER=aliyun

# CDN 加速域名
# 填写 CDN 服务商分配的加速域名
CDN_DOMAIN=

# 源站地址
# CDN 回源时访问的地址
CDN_ORIGIN=

# CDN 缓存时间（秒）
# 静态资源的缓存有效期
CDN_CACHE_TTL=86400

# CDN 缓存策略
# no-cache: 每次都验证
# cache: 长期缓存
# custom: 自定义策略
CDN_CACHE_STRATEGY=cache

# CDN HTTPS 配置
# true: 使用 HTTPS
# false: 使用 HTTP
CDN_HTTPS=true

# CDN 请求头配置（JSON 格式）
# 用于添加额外的请求头
CDN_HEADERS={}

# CDN 刷新策略
# manual: 手动刷新
# auto: 自动刷新（文件更新后自动刷新）
CDN_REFRESH_STRATEGY=manual

# ============================================================
# 系统限制配置
# ============================================================

# 单用户最大会话数
# 超过后 oldest 会话会被自动清除
MAX_SESSIONS_PER_USER=5

# 请求体最大大小（MB）
# 超过此大小的请求会被拒绝
MAX_REQUEST_BODY_SIZE=100

# 响应体最大记录大小（KB）
# 日志中记录响应体时，超过此大小会截断
MAX_LOGGED_RESPONSE_SIZE=10

# 单次 API 请求最大耗时（秒）
# 超过此时间强制断开
MAX_REQUEST_DURATION=300

# 并发 WebSocket 连接数限制
# 单 IP 最大并发连接数
MAX_WS_CONNECTIONS_PER_IP=100

# APIKey 速率限制（每分钟，每 Key）
API_KEY_RATE_LIMIT=1000
