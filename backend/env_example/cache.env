# ============================================================
# TRAI Backend Environment Configuration
# 文件名: cache.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 缓存配置
# ============================================================

# ============================================================
# 缓存配置
# ============================================================

# 是否启用缓存
# true: 启用，减少重复计算
# false: 禁用，每次都从源头获取
CACHE_ENABLED=true

# 缓存存储后端
# redis: Redis 缓存（推荐）
# memory: 内存缓存（仅单进程）
# memcached: Memcached
CACHE_TYPE=redis

# 默认缓存过期时间（秒）
# 300 = 5 分钟
CACHE_DEFAULT_TIMEOUT=300

# 缓存 Key 前缀
# 用于区分不同应用的缓存
CACHE_KEY_PREFIX=trai:cache:

# 默认缓存策略
# no_cache: 不缓存
# cache_per_user: 按用户缓存
# cache_per_role: 按角色缓存
CACHE_STRATEGY_DEFAULT=no_cache

# 是否启用缓存版本控制
# true: 缓存数据有版本号
# false: 无版本控制
CACHE_VERSION_ENABLED=false

# 缓存版本号
# 修改后旧缓存会自动失效
CACHE_VERSION_KEY=1

# 是否启用缓存预热
# true: 启动时自动加载热点数据
# false: 按需加载
CACHE_WARMUP_ENABLED=false

# 预热路径列表（逗号分隔）
# 启动时访问这些路径加载数据
CACHE_WARMUP_PATHS=/api/v1/ai/models,/api/v1/system/config

# 更新时是否自动失效相关缓存
# true: 数据更新时清除缓存
# false: 等待缓存自然过期
CACHE_INVALIDATE_ON_UPDATE=true

# 缓存失效匹配模式
CACHE_INVALIDATE_PATTERNS=trai:cache:*:*:*
