# ============================================================
# TRAI Backend Environment Configuration
# 文件名: database.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 数据库配置
# ============================================================

# ============================================================
# 数据库配置 (PostgreSQL)
# ============================================================

# 数据库主机地址
DB_HOST=localhost

# 数据库监听端口（PostgreSQL 默认 5432）
DB_PORT=5432

# 数据库名称
DB_NAME=trai

# 数据库用户名
DB_USER=your-db-user

# 数据库密码
# 【重要】生产环境必须使用强密码
DB_PASSWORD=your-db-password

# 数据库连接池大小
# 推荐值: CPU 核心数的 2-4 倍
# 影响: 同时可执行的数据库查询数
DB_POOL_SIZE=20

# 连接池最大溢出数量
# 当连接池满时，最多允许创建的额外连接数
# 设置过大可能导致数据库连接数爆满
DB_MAX_OVERFLOW=10

# 从连接池获取连接的超时时间（秒）
# 超过此时间未获取到连接将抛出异常
DB_POOL_TIMEOUT=30

# 连接回收时间（秒）
# 连接空闲超过此时间后会被回收重建
# 防止连接因长时间空闲而被数据库关闭
DB_POOL_RECYCLE=3600

# 是否打印 SQL 语句到日志
# true: 开发环境便于调试
# false: 生产环境提升性能、减少日志量
DB_ECHO=false

# 是否在建立连接前发送 Ping 测试
# true: 检测连接是否有效，避免使用已断开的连接
# 推荐: 始终开启
DB_PRE_PING=true

# 额外的数据库连接参数（JSON 格式）
# 示例: {"connect_timeout": 10, "application_name": "trai"}
# 用于传递数据库驱动特定的配置
DB_CONNECT_ARGS={}

# ============================================================
# 数据库读写分离配置
# ============================================================

# 是否启用读写分离
# true: 启用，读操作使用副本库
# false: 所有操作使用主库
DB_REPLICA_ENABLED=false

# 读副本数据库主机地址
DB_REPLICA_HOST=localhost

# 读副本数据库端口
DB_REPLICA_PORT=5432

# 读副本数据库名称
DB_REPLICA_NAME=trai_db

# 读副本数据库用户名
DB_REPLICA_USER=trai_user

# 读副本数据库密码
DB_REPLICA_PASSWORD=your-replica-password

# ============================================================
# 数据库迁移配置 (Alembic)
# ============================================================

# 是否启用数据库迁移功能
# true: 启用，允许通过 alembic 命令管理数据库结构
# false: 禁用，手动管理数据库结构
ALEMBIC_ENABLED=true

# Alembic 配置文件路径
ALEMBIC_CONFIG=alembic.ini

# ============================================================
# 数据库连接池监控配置
# ============================================================

# 是否启用连接池监控
# true: 监控连接池状态并记录日志
# false: 禁用
DB_POOL_MONITOR_ENABLED=false

# 连接池告警阈值
# 达到此使用比例时发送警告
DB_POOL_WARN_THRESHOLD=0.75

# 连接池严重告警阈值
# 达到此使用比例时发送严重警告
DB_POOL_CRITICAL_THRESHOLD=0.90

# 连接池状态检查间隔（秒）
DB_POOL_CHECK_INTERVAL=30

# 是否记录连接池事件
# true: 记录连接获取/释放/超时等事件
# false: 不记录
DB_POOL_LOG_EVENTS=true

# 连接泄漏检测
# true: 检测长时间未释放的连接
# false: 不检测
DB_POOL_LEAK_DETECTION=false

# 连接泄漏阈值（秒）
# 连接持有超过此时间判定为泄漏
DB_POOL_LEAK_THRESHOLD=60

# 连接池满时是否等待
# true: 等待获取连接
# false: 直接报错
DB_POOL_WAIT_ON_FULL=true

# 连接池最大等待时间（秒）
DB_POOL_MAX_WAIT=30

# 是否在启动时预热连接池
# true: 启动时预先创建连接
# false: 按需创建
DB_POOL_WARM_ON_START=false

# ============================================================
# 多租户配置
# ============================================================

# 是否启用多租户
# true: 支持多个独立租户
# false: 单租户模式
MULTITENANT_ENABLED=false

# 多租户隔离策略
# shared: 共享数据库，通过 tenant_id 字段隔离
# schema: 每个租户独立数据库 schema
# database: 每个租户独立数据库
MULTITENANT_STRATEGY=shared

# 租户 ID 字段名
# 用于在共享数据库模式下区分租户
MULTITENANT_FIELD=tenant_id

# 超级管理员租户 ID
# 此租户可以管理所有其他租户
MULTITENANT_SUPER_TENANT_ID=00000000-0000-0000-0000-000000000000

# 租户创建配额
# 单个租户允许创建的最大资源数（-1 表示无限制）
MULTITENANT_MAX_USERS=-1
MULTITENANT_MAX_PROJECTS=-1
MULTITENANT_MAX_STORAGE_GB=100

# ============================================================
# 数据备份配置
# ============================================================

# 是否启用自动备份
# true: 定期备份数据库和文件
# false: 禁用自动备份
BACKUP_ENABLED=false

# 备份调度 cron 表达式
# 默认: 每天凌晨 2 点
# 格式: 分 时 日 月 周
BACKUP_SCHEDULE=0 2 * * *

# 备份保留天数
# 超过此时间的备份将被删除
BACKUP_RETENTION_DAYS=30

# 备份存储类型
# local: 本地存储
# s3: S3 兼容对象存储
# ftp: FTP 服务器
BACKUP_STORAGE_TYPE=local

# 本地备份目录
BACKUP_LOCAL_PATH=/data/backups

# S3 备份存储桶名称
BACKUP_S3_BUCKET=

# S3 备份路径前缀
BACKUP_S3_PREFIX=backups/

# 备份加密密钥（可选）
# 用于加密备份文件，需妥善保管
BACKUP_ENCRYPTION_KEY=

# 是否备份文件上传
# true: 同时备份 S3 中的用户文件
# false: 仅备份数据库
BACKUP_INCLUDE_FILES=false

# 备份压缩格式
# zip: ZIP 压缩
# gzip: GZIP 压缩
# none: 不压缩
BACKUP_COMPRESSION=gzip