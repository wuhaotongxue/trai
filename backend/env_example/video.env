# ============================================================
# TRAI Backend Environment Configuration
# 文件名: video.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 视频生成配置
# ============================================================

# ============================================================
# 视频生成配置
# ============================================================

# 视频生成服务提供商
# modelscope: 魔塔社区
# openai: OpenAI Sora
# runwayml: Runway ML
# pika: Pika Labs
# kling: 阿里云通义万相
VIDEO_PROVIDER=modelscope

# 魔塔社区视频生成模型
MODELSCOPE_VIDEO_MODEL=I2VGen-XL/I2VGenXL_HD

# 视频时长（秒）
MODELSCOPE_VIDEO_DURATION=5

# 视频帧率（fps）
# 24: 电影标准
# 30: 通用
# 60: 高清流畅
MODELSCOPE_VIDEO_FPS=24

# 视频分辨率
# 480p: 标清
# 720p: 高清
# 1080p: 全高清
MODELSCOPE_VIDEO_RESOLUTION=720p
