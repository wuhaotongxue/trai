# ============================================================
# TRAI Backend Environment Configuration
# 文件名: logging_basic.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 日志基础配置
# ============================================================

# ============================================================
# 日志配置
# ============================================================

# 全局日志级别
# DEBUG: 最详细，包含调试信息
# INFO: 正常运行信息
# WARNING: 警告信息
# ERROR: 错误信息
# CRITICAL: 严重错误
# 建议: 开发环境 DEBUG，生产环境 INFO
LOG_LEVEL=INFO

# 日志根目录（相对于 backend 根目录）
# 所有日志文件将存放在此目录下
LOG_ROOT_PATH=./logs

# 是否启用文件日志
# true: 日志写入文件
# false: 仅输出到控制台
LOG_FILE_ENABLED=true

# 日志文件保留天数
# 超过此时间的日志文件将被删除
LOG_FILE_RETENTION=30days

# 日志文件压缩方式
# zip: ZIP 压缩（推荐，压缩率高）
# gzip: GZIP 压缩
# 无: 不压缩
LOG_FILE_COMPRESSION=zip

# ============================================================
# 日志文件分离配置
# ============================================================

# 应用主日志文件路径
# 记录应用程序正常运行日志
LOG_FILE_APP=logs/app.log

# 错误日志文件路径
# 仅记录 ERROR 和 CRITICAL 级别日志
LOG_FILE_ERROR=logs/error.log

# 访问日志文件路径
# 记录所有 HTTP 请求
LOG_FILE_ACCESS=logs/access.log

# 安全日志文件路径
# 记录登录、权限等安全相关事件
LOG_FILE_SECURITY=logs/security.log

# 审计日志文件路径
# 记录数据变更、资源操作等
LOG_FILE_AUDIT=logs/audit.log

# SQL 日志文件路径
# 记录数据库查询（开发环境）
LOG_FILE_SQL=logs/sql.log

# Celery 任务日志文件路径
# 记录异步任务执行日志
LOG_FILE_CELERY=logs/celery.log

# WebSocket 日志文件路径
# 记录 WebSocket 连接和消息
LOG_FILE_WEBSOCKET=logs/websocket.log

# ============================================================
# 控制台日志配置
# ============================================================

# 是否启用控制台日志
# true: 日志输出到终端
# false: 不输出到终端
LOG_CONSOLE_ENABLED=true

# 控制台日志是否着色
# true: 不同级别用不同颜色（开发环境推荐）
# false: 无颜色
LOG_CONSOLE_COLORIZE=true

# ============================================================
# 日志格式配置
# ============================================================

# 日志输出格式
# %(asctime)s: 时间
# %(name)s: 日志记录器名称
# %(process)d: 进程 ID
# %(thread)d: 线程 ID
# %(levelname)s: 日志级别
# %(message)s: 日志消息
LOG_FORMAT=%(asctime)s - %(name)s - [%(process)d] - [%(thread)d] - %(levelname)s - %(message)s

# 日期格式
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# 是否使用 JSON 格式输出日志
# true: 输出 JSON 格式，便于日志收集系统解析
# false: 输出文本格式
LOG_JSON_ENABLED=false
