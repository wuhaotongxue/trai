# ============================================================
# TRAI Backend Environment Configuration
# 文件名: app.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 应用基础配置
# ============================================================

# ============================================================
# 应用基础配置
# ============================================================

# 应用名称，用于标识和日志输出
APP_NAME=TRAI Backend

# 应用版本号，用于版本管理和兼容性检查
APP_VERSION=1.0.0

# 调试模式开关（生产环境必须设为 false）
# true: 开启详细错误日志、启用调试功能
# false: 关闭调试、提高性能
APP_DEBUG=true

# 应用监听地址（0.0.0.0 表示监听所有网络接口）
APP_HOST=0.0.0.0

# 应用监听端口，用于接收 HTTP 请求
APP_PORT=5666

# 应用运行环境（决定配置加载和行为）
# development: 开发环境，功能全开，错误详细
# staging: 预发布环境，与生产一致，用于测试
# production: 生产环境，性能优化，安全加固
APP_ENV=development

# 应用密钥，用于加密敏感数据（如会话、Token）
# 【重要】生产环境必须使用随机生成的复杂密钥（至少 32 字符）
APP_SECRET_KEY=your-app-secret-key-change-in-production

# 服务器时区设置，影响所有时间相关操作
# 格式: IANA 时区数据库名称
# 示例: Asia/Shanghai, UTC, America/New_York
TIMEZONE=Asia/Shanghai

# 系统默认语言，影响错误消息、文档等
# 格式: ISO 639-1 语言代码 + ISO 3166-1 国家代码
# 示例: zh-CN, en-US
LANGUAGE=zh-CN

# ============================================================
# 应用启动配置（Gunicorn/Uvicorn）
# ============================================================

# 工作进程数，推荐设置为 CPU 核心数的 2-4 倍
# 计算方式: 2-4 × CPU核心数
# 示例: 4 核 CPU 可设置为 8-16
WORKERS=4

# 工作进程类型，决定并发处理方式
# sync: 同步进程，适合 CPU 密集型任务
# gevent: 协程进程，适合 IO 密集型任务（高并发）
# uvicorn.workers.UvicornWorker: ASGI 异步进程
WORKER_CLASS=sync

# 每个工作进程的最大并发连接数
# 建议值: 1000-4000，根据内存和业务调整
WORKER_CONNECTIONS=1000

# HTTP Keep-Alive 超时时间（秒）
# 0: 禁用 Keep-Alive
# 正数: 保持连接的时间，期间可复用 TCP 连接
KEEPALIVE=5

# 请求处理超时时间（秒）
# 超过此时间未完成的请求将被强制终止
TIMEOUT=30

# 优雅停止超时时间（秒）
# 收到停止信号后，等待现有请求完成的最长时间
# 超过此时间仍未完成的请求将被强制终止
GRACEFUL_TIMEOUT=30

# ============================================================
# 开发环境增强配置
# ============================================================

# 是否启用热重载
# true: 修改代码后自动重启
# false: 需要手动重启
RELOAD=false

# 开发工具启用状态
# true: 启用 debug 工具栏等
# false: 禁用
DEV_TOOLS_ENABLED=false

# SQL 执行日志
# true: 记录所有执行的 SQL 语句
# false: 不记录
SQL_TRACE_ENABLED=false

# 请求日志详细程度
# minimal: 仅记录路径和状态码
# standard: 记录路径、状态码、耗时
# detailed: 记录请求头、响应头、完整参数
REQUEST_LOG_LEVEL=standard

# Mock 外部服务
# true: 外部 HTTP 请求返回假数据
# false: 真实请求
MOCK_EXTERNAL=false

# ============================================================
# 测试配置
# ============================================================

# 是否为测试模式
# true: 使用测试配置
# false: 使用生产配置
TESTING=false

# 测试数据库主机
TEST_DB_HOST=localhost

# 测试数据库端口
TEST_DB_PORT=5432

# 测试数据库名称
TEST_DB_NAME=trai_test

# 测试 Redis 数据库
TEST_REDIS_DB=15

# 是否启用覆盖率统计
# true: 收集测试覆盖率
# false: 不收集
TEST_COVERAGE_ENABLED=false

# 最低覆盖率要求（百分比）
# 低于此值测试失败
TEST_COVERAGE_MIN=80

# 并行测试工作进程数
# 0: 串行执行
# 正数: 并行进程数
TEST_PARALLEL_WORKERS=4

# 是否随机测试顺序
# true: 随机执行测试用例
# false: 按定义顺序执行
TEST_RANDOMIZE_ORDER=false

# ============================================================
# 测试 Mock 配置
# ============================================================

# 是否 Mock LLM 调用
# true: 使用假数据，不调用真实 API
# false: 调用真实 API
TEST_MOCK_LLM=true

# 是否 Mock S3 操作
# true: 使用本地存储
# false: 使用真实 S3
TEST_MOCK_S3=true

# 是否 Mock 企业微信
# true: 使用假数据
# false: 使用真实企业微信 API
TEST_MOCK_WECHAT=false

# ============================================================
# 集成测试配置
# ============================================================

# 集成测试数据库名称
TEST_INTEGRATION_DB_NAME=trai_integration_test

# 集成测试 Redis 数据库
TEST_INTEGRATION_REDIS_DB=14