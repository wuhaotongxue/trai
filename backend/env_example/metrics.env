# ============================================================
# TRAI Backend Environment Configuration
# 文件名: metrics.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 监控与指标配置
# ============================================================

# ============================================================
# 监控与指标配置
# ============================================================

# 是否启用监控指标
# true: 启用，收集运行时指标
# false: 禁用
METRICS_ENABLED=true

# 监控指标端口
# 独立于主应用端口
METRICS_PORT=9090

# Prometheus 指标端点路径
METRICS_PATH=/metrics

# 健康检查端点路径
HEALTH_CHECK_PATH=/system/health

# ============================================================
# 健康检查配置
# ============================================================

# 是否返回详细信息
# true: 返回各组件详细状态
# false: 只返回是否健康
HEALTH_CHECK_DETAILED=true

# 是否检查私网依赖
# true: 检查内网服务（数据库、Redis）
# false: 跳过私网依赖
HEALTH_CHECK_ALLOW_PRIVATE=true

# 是否检查数据库连接
HEALTH_CHECK_DB=true

# 是否检查 Redis 连接
HEALTH_CHECK_REDIS=true

# 是否检查 S3 连接
HEALTH_CHECK_S3=true

# 是否检查 LLM 服务
HEALTH_CHECK_LLM=true

# 是否检查外部服务
HEALTH_CHECK_EXTERNAL=true

# ============================================================
# 系统健康检查增强配置
# ============================================================

# 健康检查详细级别
# minimal: 仅返回状态
# standard: 返回各组件状态
# detailed: 返回详细指标
HEALTH_CHECK_LEVEL=standard

# 健康检查包含的组件
# 逗号分隔，可选值: database,redis,s3,celery,external_api
HEALTH_CHECK_COMPONENTS=database,redis,s3

# 外部服务健康检查
# true: 检查外部 API 可达性
# false: 跳过外部检查
HEALTH_CHECK_EXTERNAL=true

# 外部服务检查超时（秒）
HEALTH_CHECK_EXTERNAL_TIMEOUT=5

# 外部服务检查 URL 列表（JSON 数组）
HEALTH_CHECK_EXTERNAL_URLS=[]

# ============================================================
# 指标收集配置
# ============================================================

# 指标收集器类型
# prometheus: Prometheus（推荐）
# statsd: StatsD
# datadog: Datadog
METRICS_COLLECTOR=prometheus

# 指标导出格式
# prometheus: Prometheus 格式
# json: JSON 格式
# influxdb: InfluxDB 格式
METRICS_EXPORT_FORMAT=prometheus

# Prometheus 多进程目录
# 用于多 Worker 进程模式
PROMETHEUS_MULTIPROC_DIR=./metrics

# Prometheus 端口
PROMETHEUS_PORT=9091

# ============================================================
# StatsD 配置
# ============================================================

# StatsD 主机地址
STATSD_HOST=localhost

# StatsD 端口
STATSD_PORT=8125

# 指标前缀（用于区分不同服务）
STATSD_PREFIX=trai

# ============================================================
# Grafana 配置
# ============================================================

# 是否启用 Grafana 集成
# true: 启用，可直接在 Grafana 查看
# false: 禁用
GRAFANA_ENABLED=false

# Grafana 服务地址
GRAFANA_URL=http://localhost:3000

# Grafana API Key
# 用于认证和授权
GRAFANA_API_KEY=

# Grafana Dashboard UID
# 用于指定展示哪个 Dashboard
GRAFANA_DASHBOARD_UID=trai-backend

# ============================================================
# 性能监控配置
# ============================================================

# 是否启用性能监控
# true: 记录请求响应时间等
# false: 禁用
PERFORMANCE_MONITORING_ENABLED=true

# 性能采样率（0-1）
# 1.0 = 记录所有请求
# 降低可减少性能开销
PERFORMANCE_MONITORING_SAMPLE_RATE=1.0

# 是否在性能数据中包含请求头
# true: 包含（便于调试）
# false: 不包含（减少数据量）
PERFORMANCE_MONITORING_INCLUDE_HEADERS=false