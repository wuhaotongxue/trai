# ============================================================
# TRAI Backend Environment Configuration
# 文件名: logging_aggregation.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 日志聚合配置
# ============================================================

# ============================================================
# 日志聚合配置（多实例汇总）
# ============================================================

# 是否启用日志聚合
# true: 发送到日志收集服务（如 ELK）
# false: 本地存储
LOG_AGGREGATION_ENABLED=false

# 日志聚合服务地址
LOG_AGGREGATION_HOST=localhost

# 日志聚合服务端口
LOG_AGGREGATION_PORT=5044

# 传输协议
# tcp: 可靠传输（推荐）
# udp: 高效但不保证到达
# http: HTTP 协议
LOG_AGGREGATION_PROTOCOL=tcp

# ============================================================
# Elasticsearch 日志配置
# ============================================================

# 是否启用 Elasticsearch 日志
# true: 日志同时发送到 ES
# false: 仅本地存储
ELK_ENABLED=false

# Elasticsearch 主机地址
ELK_HOST=localhost

# Elasticsearch 端口
ELK_PORT=9200

# Elasticsearch 索引前缀
# 实际索引名: {prefix}-YYYY.MM.DD
ELK_INDEX_PREFIX=trai-logs

# Elasticsearch 用户名（可选）
ELK_USERNAME=

# Elasticsearch 密码（可选）
ELK_PASSWORD=

# 是否使用 HTTPS
# true: 使用 HTTPS 连接
# false: 使用 HTTP
ELK_USE_SSL=false

# Elasticsearch 请求超时（秒）
ELK_TIMEOUT=30

# 日志批量发送大小
# 达到此数量后批量发送到 ES
ELK_BATCH_SIZE=1000

# ============================================================
# 日志通道详细配置
# ============================================================

# ============================================================
# 应用日志通道
# ============================================================

# 是否启用应用日志通道
LOG_CHANNEL_APP_ENABLED=true

# 应用日志级别
LOG_CHANNEL_LEVEL_APP=INFO

# 应用日志文件路径
LOG_CHANNEL_APP_FILE=logs/app.log

# ============================================================
# 错误日志通道
# ============================================================

# 是否启用错误日志通道
LOG_CHANNEL_ERROR_ENABLED=true

# 错误日志级别
# 建议: ERROR，只记录错误
LOG_CHANNEL_LEVEL_ERROR=ERROR

# 错误日志文件路径
LOG_CHANNEL_ERROR_FILE=logs/error.log

# 是否包含堆栈跟踪信息
# true: 记录完整的异常堆栈
# false: 只记录错误消息
LOG_CHANNEL_ERROR_INCLUDE_STACK_TRACE=true

# ============================================================
# 访问日志通道
# ============================================================

# 是否启用访问日志通道
LOG_CHANNEL_ACCESS_ENABLED=true

# 访问日志级别
LOG_CHANNEL_LEVEL_ACCESS=INFO

# 访问日志文件路径
LOG_CHANNEL_ACCESS_FILE=logs/access.log

# 访问日志格式
# json: JSON 格式（便于分析）
# text: 文本格式（便于阅读）
LOG_CHANNEL_ACCESS_FORMAT=json

# 是否包含请求头信息
# true: 记录请求头
# false: 不记录（减少日志大小）
LOG_CHANNEL_ACCESS_INCLUDE_HEADERS=false

# 是否包含请求体信息
# true: 记录请求体
# false: 不记录（保护敏感数据）
LOG_CHANNEL_ACCESS_INCLUDE_BODY=false

# 是否包含响应体信息
# true: 记录响应体
# false: 不记录（减少日志大小）
LOG_CHANNEL_ACCESS_INCLUDE_RESPONSE=false

# ============================================================
# 安全日志通道
# ============================================================

# 是否启用安全日志通道
LOG_CHANNEL_SECURITY_ENABLED=true

# 安全日志级别
# 建议: WARNING 及以上
LOG_CHANNEL_LEVEL_SECURITY=WARNING

# 安全日志文件路径
LOG_CHANNEL_SECURITY_FILE=logs/security.log

# 是否记录客户端 IP 地址
LOG_CHANNEL_SECURITY_INCLUDE_IP=true

# 是否记录 User-Agent
LOG_CHANNEL_SECURITY_INCLUDE_USER_AGENT=true