# ============================================================
# TRAI Backend Environment Configuration
# 文件名: sms.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 短信配置
# ============================================================

# ============================================================
# 短信配置
# ============================================================

# 是否启用短信功能
# true: 可以发送短信
# false: 禁用短信
SMS_ENABLED=false

# ============================================================
# 短信通用配置
# ============================================================

# 默认短信发送渠道
SMS_DEFAULT_PROVIDER=aliyun

# 短信发送超时（秒）
SMS_TIMEOUT=30

# 短信每日发送上限
# 用于成本控制
SMS_DAILY_LIMIT=500

# 短信冷却时间（秒）
# 同一手机号发送间隔
# 防止短信轰炸
SMS_COOLDOWN_SECONDS=60

# 验证码有效期（秒）
# 超过此时间验证码失效
SMS_VERIFY_CODE_EXPIRE=300

# ============================================================
# 短信场景配置
# ============================================================

# 登录验证码发送渠道
SMS_SCENE_LOGIN_PROVIDERS=aliyun

# 注册验证码发送渠道
SMS_SCENE_REGISTER_PROVIDERS=aliyun

# 密码重置验证码发送渠道
SMS_SCENE_RESET_PASSWORD_PROVIDERS=aliyun

# 绑定手机验证码发送渠道
SMS_SCENE_BIND_PHONE_PROVIDERS=aliyun

# ============================================================
# 阿里云短信配置
# ============================================================

# 是否启用阿里云短信
SMS_ALIYUN_ENABLED=false

# Access Key ID
SMS_ALIYUN_ACCESS_KEY=

# Access Key Secret
SMS_ALIYUN_ACCESS_SECRET=

# 短信签名名称
SMS_ALIYUN_SIGN_NAME=TRAI

# 登录验证码模板 ID
SMS_ALIYUN_TEMPLATE_LOGIN=SMS_xxxxxxx

# 注册验证码模板 ID
SMS_ALIYUN_TEMPLATE_REGISTER=SMS_xxxxxxx

# 密码重置模板 ID
SMS_ALIYUN_TEMPLATE_RESET_PASSWORD=SMS_xxxxxxx

# 绑定手机模板 ID
SMS_ALIYUN_TEMPLATE_BIND_PHONE=SMS_xxxxxxx

# 区域 ID
SMS_ALIYUN_REGION_ID=cn-hangzhou

# ============================================================
# 腾讯云短信配置
# ============================================================

# 是否启用腾讯云短信
SMS_TENCENT_ENABLED=false

# Secret ID
SMS_TENCENT_SECRET_ID=

# Secret Key
SMS_TENCENT_SECRET_KEY=

# SDK AppID
SMS_TENCENT_APP_ID=1400xxxxxx

# 短信签名
SMS_TENCENT_SIGN_NAME=TRAI

# 登录验证码模板 ID
SMS_TENCENT_TEMPLATE_LOGIN=xxxxxxx

# 注册验证码模板 ID
SMS_TENCENT_TEMPLATE_REGISTER=xxxxxxx

# 密码重置模板 ID
SMS_TENCENT_TEMPLATE_RESET_PASSWORD=xxxxxxx

# 绑定手机模板 ID
SMS_TENCENT_TEMPLATE_BIND_PHONE=xxxxxxx

# 区域
SMS_TENCENT_REGION=ap-guangzhou

# ============================================================
# 华为云短信配置
# ============================================================

# 是否启用华为云短信
SMS_HUAWEI_ENABLED=false

# API 端点
SMS_HUAWEI_ENDPOINT=https://smsapi.cn-north-4.myhuaweicloud.com

# Access Key ID
SMS_HUAWEI_ACCESS_KEY=

# Secret Key
SMS_HUAWEI_SECRET_KEY=

# 签名 ID
SMS_HUAWEI_SIGNATURE_ID=

# App Key
SMS_HUAWEI_APP_KEY=

# 登录验证码模板 ID
SMS_HUAWEI_TEMPLATE_LOGIN=xxxxxxxxxxxxxxxx

# 注册验证码模板 ID
SMS_HUAWEI_TEMPLATE_REGISTER=xxxxxxxxxxxxxxxx

# 密码重置模板 ID
SMS_HUAWEI_TEMPLATE_RESET_PASSWORD=xxxxxxxxxxxxxxxx

# 绑定手机模板 ID
SMS_HUAWEI_TEMPLATE_BIND_PHONE=xxxxxxxxxxxxxxxx

# ============================================================
# 企业微信短信（消息推送）配置
# ============================================================

# 是否启用企业微信消息推送
SMS_WECOM_ENABLED=false

# 企业 ID
SMS_WECOM_CORP_ID=wwxxxxxxxxxxxxxx

# 应用 Agent ID
SMS_WECOM_AGENT_ID=1000001

# 应用 Secret
SMS_WECOM_SECRET=

# 消息模板 ID
SMS_WECOM_TEMPLATE_ID=xxxxxxx

# ============================================================
# 钉钉短信（消息推送）配置
# ============================================================

# 是否启用钉钉消息推送
SMS_DINGTALK_ENABLED=false

# Access Key ID
SMS_DINGTALK_ACCESS_KEY=

# Access Key Secret
SMS_DINGTALK_ACCESS_SECRET=

# 签名名称
SMS_DINGTALK_SIGN_NAME=TRAI

# 模板 CODE
SMS_DINGTALK_TEMPLATE_CODE=

# ============================================================
# 飞书短信（消息推送）配置
# ============================================================

# 是否启用飞书消息推送
SMS_FEISHU_ENABLED=false

# App ID
SMS_FEISHU_APP_ID=your-feishu-app-id

# App Secret
SMS_FEISHU_APP_SECRET=

# 消息模板 ID
SMS_FEISHU_TEMPLATE_ID=xxxxxxx

# ============================================================
# Twilio 国际短信配置
# ============================================================

# 是否启用 Twilio
SMS_TWILIO_ENABLED=false

# Account SID
SMS_TWILIO_ACCOUNT_SID=

# Auth Token
SMS_TWILIO_AUTH_TOKEN=

# 发件号码（E.164 格式）
SMS_TWILIO_FROM_NUMBER=+1234567890