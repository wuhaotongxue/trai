# ============================================================
# TRAI Backend Environment Configuration
# 文件名: websocket.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: WebSocket 配置
# ============================================================

# ============================================================
# WebSocket 配置
# ============================================================

# 是否启用 WebSocket
# true: 支持实时双向通信
# false: 仅 HTTP
WEBSOCKET_ENABLED=true

# WebSocket 端点路径
WEBSOCKET_PATH=/ws

# 心跳间隔（秒）
# 定期发送 ping 保持连接活跃
WEBSOCKET_PING_INTERVAL=30

# 心跳超时（秒）
# 超过此时间未收到 pong 判定为断开
WEBSOCKET_PING_TIMEOUT=10

# 最大消息大小（字节）
# 10485760 = 10MB
WEBSOCKET_MAX_MESSAGE_SIZE=10485760

# WebSocket 房间前缀
WEBSOCKET_ROOM_PREFIX=room:

# WebSocket 用户前缀
WEBSOCKET_USER_PREFIX=user:

# 每个用户最大房间数
WEBSOCKET_MAX_ROOMS_PER_USER=10
