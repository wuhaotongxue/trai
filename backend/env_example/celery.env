# ============================================================
# TRAI Backend Environment Configuration
# 文件名: celery.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 消息队列配置（Celery）
# ============================================================

# ============================================================
# 消息队列配置 (Celery)
# ============================================================

# 是否启用 Celery 异步任务
# true: 启用，耗时任务异步执行
# false: 禁用，所有任务同步执行
CELERY_ENABLED=false

# Broker 类型
# redis: Redis 消息队列（推荐）
# rabbitmq: RabbitMQ（功能更强）
# sqs: AWS SQS（云服务）
CELERY_BROKER_TYPE=redis

# Redis Broker 连接地址
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery 结果后端地址
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# 任务序列化方式
# json: JSON 格式，兼容性最好
# pickle: Python pickle，高效但有安全风险
# msgpack: 高效二进制格式
CELERY_TASK_SERIALIZER=json

# 结果序列化方式
CELERY_RESULT_SERIALIZER=json

# 接受的序列化格式
CELERY_ACCEPT_CONTENT=json

# Celery 时区（影响定时任务执行时间）
CELERY_TIMEZONE=Asia/Shanghai

# 是否使用 UTC 时间
CELERY_ENABLE_UTC=true

# 是否追踪任务状态
# true: 可以查询任务状态
# false: 任务执行即忘，不追踪
CELERY_TASK_TRACK_STARTED=true

# ============================================================
# Celery 任务限制配置
# ============================================================

# 任务硬超时时间（秒）
# 超过此时间任务将被强制终止
CELERY_TASK_TIME_LIMIT=3600

# 任务软超时时间（秒）
# 超过此时间发送警告，可自行处理
CELERY_TASK_SOFT_TIME_LIMIT=3300

# ============================================================
# Celery 队列配置
# ============================================================

# 可用队列列表
# celery: 普通队列
# celery_high: 高优先级队列
# celery_low: 低优先级队列
CELERY_TASK_QUEUES=celery,celery_high,celery_low

# 默认队列（未指定时使用）
CELERY_TASK_DEFAULT_QUEUE=celery

# 默认交换机名称
CELERY_TASK_DEFAULT_EXCHANGE=celery

# 默认路由键
CELERY_TASK_DEFAULT_ROUTING_KEY=celery

# ============================================================
# Celery Worker 配置
# ============================================================

# 用户优先级是否反转
# true: 数字越大优先级越高
# false: 数字越小优先级越高
CELERY_TASK_INVERT_USER_PRIO=true

# Worker 预取任务数
# 建议值: CPU 核心数 × 4
# 影响并发处理能力
CELERY_WORKER_PREFETCH_MULTIPLIER=4

# Worker 最大任务数
# 超过此数后 Worker 会重启（防止内存泄漏）
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# ============================================================
# Celery 结果配置
# ============================================================

# 结果过期时间（秒）
# 超过此时间的结果会被删除
CELERY_RESULT_EXPIRES=3600

# 是否持久化结果
# true: 结果存入后端
# false: 结果不存储
CELERY_RESULT_PERSISTENT=true

# 结果压缩方式
# gzip: 压缩存储
# 无: 不压缩
CELERY_RESULT_COMPRESSION=gzip

# ============================================================
# Celery 定时任务配置
# ============================================================

# Beat 调度器
# celery.beat:PersistentScheduler: 基于文件的持久化调度器
CELERY_BEAT_SCHEDULER=celery.beat:PersistentScheduler

# Beat 同步周期（秒）
# 定期将调度器状态同步到磁盘
CELERY_BEAT_SYNC_EVERY=3

# ============================================================
# Celery 监控配置
# ============================================================

# 是否发送任务事件
# true: 允许监控工具追踪任务
# false: 禁用事件
CELERY_SEND_EVENTS=true

# 是否发送任务提交事件
CELERY_SEND_TASK_SENT_EVENT=true

# 任务错误时是否发送邮件通知
CELERY_SEND_TASK_ERROR_EMAILS=false

# Worker 是否发送任务事件
CELERY_WORKER_SEND_TASK_EVENTS=true

# ============================================================
# Celery 死信队列配置
# ============================================================

# 是否启用死信队列
# true: 失败的任务会进入死信队列，而不是直接丢弃
# false: 失败任务直接丢弃
CELERY_DLQ_ENABLED=true

# 死信队列名称
# 失败任务会被路由到这个队列
CELERY_DLQ_NAME=celery.dlq

# 死信队列交换机名称
CELERY_DLQ_EXCHANGE=celery.dlx

# 死信队列路由键
CELERY_DLQ_ROUTING_KEY=celery.dlx

# 任务失败重试次数
# 超过此次数后进入死信队列
CELERY_TASK_MAX_RETRIES=3

# 重试延迟（秒）
# 每次重试之间的等待时间
# 支持指数退避格式: 60,300,900 (每次翻倍)
CELERY_TASK_RETRY_DELAY=60

# 是否启用指数退避重试
# true: 重试延迟按指数增长
# false: 固定间隔重试
CELERY_TASK_RETRY_EXPONENTIAL=false

# 最大重试延迟（秒）
# 指数退避时的最大延迟上限
CELERY_TASK_MAX_RETRY_DELAY=3600

# 任务超时时间（秒）
# 超时后任务被标记为失败
CELERY_TASK_SOFT_TIME_LIMIT=300

# 任务硬超时时间（秒）
# 超过此时间强制终止任务
CELERY_TASK_TIME_LIMIT=600

# 任务确认模式
# always: 任务执行后发送 ACK
# manual: 手动确认
# none: 不确认（不推荐，可能丢任务）
CELERY_TASK_ACKS_LATE=true

# 任务预取数量
# 每个 worker 预先获取的任务数
CELERY_WORKER_PREFETCH_MULTIPLIER=4

# 任务优先级范围
# 0-9，数字越大优先级越高
CELERY_TASK_PRIORITY_RANGE=0,9

# 死信任务保留时间（天）
# 超过此天数自动清理
CELERY_DLQ_RETENTION_DAYS=7

# 死信任务告警
# true: 任务进入死信队列时发送告警
# false: 不告警
CELERY_DLQ_ALERT_ENABLED=false

# 死信任务告警阈值
# 达到此数量时触发告警
CELERY_DLQ_ALERT_THRESHOLD=10

# 死信队列监控间隔（秒）
CELERY_DLQ_CHECK_INTERVAL=300

# 是否自动重试死信队列中的任务
# true: 自动重试
# false: 人工处理
CELERY_DLQ_AUTO_RETRY=false

# 自动重试最大次数
CELERY_DLQ_AUTO_RETRY_MAX=1

# 任务急驰（eager）模式
# true: 任务在主进程中同步执行（用于测试）
# false: 任务通过 broker 异步执行
CELERY_TASK_ALWAYS_EAGER=false

# 任务结果后端
# redis: 存储到 Redis
# memcached: 存储到 Memcached
# sqlalchemy: 存储到数据库
# none: 不存储结果
CELERY_RESULT_BACKEND=none

# 任务结果过期时间（秒）
# 超过此时间结果自动删除
CELERY_RESULT_EXPIRES=86400

# 内容类型
CELERY_ACCEPT_CONTENT=json

# 定期任务调度器
# redbeat: Redis-backed 调度器（高性能）
# celerybeat: 默认调度器
CELERYBEAT_SCHEDULER=celery.beat:PersistentScheduler

# 任务追踪
# true: 追踪任务执行轨迹
# false: 不追踪
CELERY_TASK_TRACK_STARTED=true

# 任务发送失败处理
# true: 发送失败时抛出异常
# false: 静默忽略
CELERY_TASK_SEND_SENT_EVENT=true
