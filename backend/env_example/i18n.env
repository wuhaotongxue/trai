# ============================================================
# TRAI Backend Environment Configuration
# 文件名: i18n.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 国际化配置
# ============================================================

# ============================================================
# 国际化配置
# ============================================================

# 是否启用国际化
# true: 支持多语言
# false: 仅使用默认语言
I18N_ENABLED=false

# 默认语言
I18N_DEFAULT_LOCALE=zh_CN

# 备用语言
# 当请求的语言不可用时使用
I18N_FALLBACK_LOCALE=en_US

# 支持的语言列表（逗号分隔）
# 格式: 语言代码_区域代码
I18N_SUPPORTED_LOCALES=zh_CN,en_US,ja_JP,ko_KR

# 语言自动检测
# true: 根据请求头自动选择语言
# false: 使用默认语言
I18N_AUTO_DETECT=true

# 语言选择优先级
# header: Accept-Language 头优先
# cookie: Cookie 中的语言设置优先
# query: URL 查询参数优先
I18N_PRIORITY=header

# 翻译文件存储目录
I18N_TRANSLATIONS_PATH=/i18n

# 是否启用语言切换 API
# true: 提供切换语言的 API
# false: 不提供
I18N_SWITCH_API_ENABLED=true

# 语言切换后是否记住
# true: 存入 Cookie/数据库
# false: 仅本次会话有效
I18N_PERSIST_SELECTION=true

# 时区自动转换
# true: 显示时间时自动转换为用户时区
# false: 使用服务器时区
I18N_AUTO_TIMEZONE=true
