# ============================================================
# TRAI Backend Environment Configuration
# 文件名: llm.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 大语言模型配置
# ============================================================

# ============================================================
# LLM 大模型配置
# ============================================================

# LLM 服务提供商选择
# openai: OpenAI GPT 系列
# azure: Azure OpenAI Service
# anthropic: Anthropic Claude 系列
# modelscope: 魔塔社区（国产，免费额度）
# local: 本地部署（如 Ollama）
LLM_PROVIDER=openai

# ============================================================
# OpenAI / DeepSeek 配置 (主要)
# ============================================================

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# DeepSeek API Base URL
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# DeepSeek Chat Model
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# DeepSeek Timeout
DEEPSEEK_TIMEOUT=120

# OpenAI API 密钥
# 从 https://platform.openai.com 获取
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI API 基础地址
# 官方: https://api.openai.com/v1
# 代理/第三方: 自行部署的代理地址
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 模型名称
# gpt-4o: 最新多模态模型，支持图像
# gpt-4-turbo: 快速版 GPT-4
# gpt-3.5-turbo: 低价快速
OPENAI_MODEL=gpt-4o

# OpenAI 单次请求最大 Token 数
# 影响单次对话长度
# 最大支持 128k tokens（GPT-4 Turbo）
OPENAI_MAX_TOKENS=4096

# OpenAI 生成温度（0-2）
# 0: 确定输出，更适合任务执行
# 0.7: 平衡创造性和准确性
# 1.5-2: 创造性输出，可能不稳定
OPENAI_TEMPERATURE=0.7

# OpenAI API 请求超时时间（秒）
# 复杂任务可能需要较长时间
OPENAI_TIMEOUT=120

# ============================================================
# 阿里云百炼 / DashScope 配置（本地开发）
# ============================================================

# 说明:
# - 本文件会落盘在本机，但已被 .gitignore 忽略，严禁提交到仓库
# - 不要在任何聊天/工单中粘贴 AccessKey Secret 或 API Key 明文
# - 百炼知识库 OpenAPI 需要阿里云 RAM AccessKey（AK/SK），不是 DashScope 的 sk-... Key
# - Region 仅用于你在代码里做默认地域选择，控制台链接 cn-beijing 对应这里填 cn-beijing
#

# DashScope API Key（sk-...，用于模型调用等；不是 OpenAPI 的 AK/SK）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# DashScope OpenAI-compatible base url
# cn-beijing: https://dashscope.aliyuncs.com/compatible-mode/v1
# ap-southeast-1: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# us-east-1: https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# DashScope OpenAI-compatible chat model
DASHSCOPE_CHAT_MODEL=qwen-turbo

# 兼容历史字段
AI_DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 阿里云 RAM AccessKey（用于百炼 OpenAPI 的签名鉴权）
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret

# 百炼 WorkspaceId（控制台左上角 Workspace Details 可见，一般为 llm-... 或 ws_...）
BAILIAN_WORKSPACE_ID=ws-your-workspace-id

# 百炼默认 Region（示例：cn-beijing）
BAILIAN_REGION=cn-beijing

# ============================================================
# 魔塔社区 ModelScope 大模型配置（推荐国内用户）
# ============================================================

# 是否启用魔塔社区
# true: 使用魔塔社区模型
# false: 使用其他配置的模型
MODELSCOPE_ENABLED=true

# 魔塔社区 API 地址
MODELSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 魔塔社区 API 密钥
# 从 https://modelscope.cn 获取
MODELSCOPE_API_KEY=sk-your-modelscope-api-key

# API 请求超时时间（秒）
MODELSCOPE_TIMEOUT=120

# 默认对话模型（用于未指定模型时）
MODELSCOPE_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct

# 默认最大 Token 数
MODELSCOPE_DEFAULT_MAX_TOKENS=4096

# 默认温度参数
MODELSCOPE_DEFAULT_TEMPERATURE=0.7

# 默认 Top-P（核采样参数）
# 控制模型考虑的 Token 范围
MODELSCOPE_DEFAULT_TOP_P=0.9

# 默认 Top-K（候选 Token 数）
# 每次只考虑概率最高的 K 个 Token
MODELSCOPE_DEFAULT_TOP_K=50

# 可用的对话模型列表（逗号分隔）
MODELSCOPE_CHAT_MODELS=Qwen/Qwen3.5-0.8B,Qwen/Qwen2.5-7B-Instruct,Qwen/Qwen2.5-14B-Instruct,Qwen/Qwen2.5-72B-Instruct

# 默认使用的对话模型
MODELSCOPE_CHAT_MODEL=Qwen/Qwen3.5-0.8B

# 可用的图像理解模型列表
MODELSCOPE_VISION_MODELS=Qwen/Qwen2-VL-7B-Instruct,Qwen/Qwen2-VL-72B-Instruct

# 默认使用的图像理解模型
MODELSCOPE_VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct

# 可用的嵌入模型列表（用于文本向量化）
MODELSCOPE_EMBEDDING_MODELS=sentence-transformers paraphrase-multilingual-MiniLM-L12-v2

# 默认使用的嵌入模型
MODELSCOPE_EMBEDDING_MODEL=sentence-transformers paraphrase-multilingual-MiniLM-L12-v2

# 可用的代码模型列表
MODELSCOPE_CODE_MODELS=Qwen/CodeQwen1.5-7B-Chat,Qwen/CodeQwen1.5-14B-Chat

# 默认使用的代码模型
MODELSCOPE_CODE_MODEL=Qwen/CodeQwen1.5-7B-Chat