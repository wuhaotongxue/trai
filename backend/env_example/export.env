# ============================================================
# TRAI Backend Environment Configuration
# 文件名: export.env
# 作者: wuhao
# 日期: 2026_05_14
# 描述: 数据导出导入配置
# ============================================================

# ============================================================
# 数据导出导入配置
# ============================================================

# 是否启用数据导出功能
# true: 允许用户导出数据
# false: 禁用
EXPORT_ENABLED=true

# 单次最大导出记录数
# 超过此数量需要分批导出
EXPORT_MAX_RECORDS=100000

# 导出分批大小
# 每批导出的记录数，用于减少内存占用
EXPORT_CHUNK_SIZE=10000

# 导出文件格式
# csv: CSV 格式（通用性强）
# xlsx: Excel 格式（支持大数据）
# json: JSON 格式（保留数据结构）
EXPORT_DEFAULT_FORMAT=csv

# 导出文件编码
# utf-8: UTF-8（推荐）
# gbk: GBK（兼容中文 Windows）
EXPORT_ENCODING=utf-8

# 是否启用数据导入功能
# true: 允许导入数据
# false: 禁用
IMPORT_ENABLED=true

# 导入验证严格模式
# true: 严格验证数据格式和必填字段
# false: 宽松验证，允许部分错误
IMPORT_VALIDATION_STRICT=true

# 导入最大文件大小（MB）
IMPORT_MAX_FILE_SIZE=50

# 导入允许的文件格式（逗号分隔）
IMPORT_ALLOWED_FORMATS=csv,xlsx,json

# 导入冲突处理策略
# skip: 跳过已存在的记录
# update: 更新已存在的记录
# error: 遇到冲突报错
IMPORT_CONFLICT_STRATEGY=skip

# 导入结果通知
# true: 导入完成后发送邮件通知
# false: 不通知
IMPORT_NOTIFY=true

# ============================================================
# Feature Flag 配置
# ============================================================

# 是否启用 Feature Flag
# true: 支持功能开关和灰度发布
# false: 所有功能直接可用
FEATURE_FLAG_ENABLED=true

# Feature Flag 提供者
# redis: Redis 存储（推荐，性能高）
# database: 数据库存储（持久化）
# config: 配置文件（仅开发环境）
FEATURE_FLAG_PROVIDER=redis

# Feature Flag 缓存 TTL（秒）
# 缓存更新时间，避免频繁查询
FEATURE_FLAG_CACHE_TTL=60

# Feature Flag 变更通知
# true: 变更时通过 WebSocket 推送通知
# false: 客户端按 TTL 刷新
FEATURE_FLAG_REALTIME=true

# Feature Flag 默认值
# 当 Flag 不存在时使用的默认值
# true: 功能默认开启
# false: 功能默认关闭
FEATURE_FLAG_DEFAULT=false
