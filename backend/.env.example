# ============================================================
# TRAI Backend Environment Configuration
# 文件名: .env
# 作者: wuhao
# 日期: 2026_04_09_11:26:19
# 描述: TRAI 后端环境配置文件（完整注释版）
# 说明: 所有配置项均带有详细中文注释，便于理解和配置
# ============================================================

# ============================================================
# 应用基础配置
# ============================================================

# 应用名称，用于标识和日志输出
APP_NAME=TRAI Backend

# 应用版本号，用于版本管理和兼容性检查
APP_VERSION=1.0.0

# 调试模式开关（生产环境必须设为 false）
# true: 开启详细错误日志、启用调试功能
# false: 关闭调试、提高性能
APP_DEBUG=true

# 应用监听地址（0.0.0.0 表示监听所有网络接口）
APP_HOST=0.0.0.0

# 应用监听端口，用于接收 HTTP 请求
APP_PORT=5666

# 应用运行环境（决定配置加载和行为）
# development: 开发环境，功能全开，错误详细
# staging: 预发布环境，与生产一致，用于测试
# production: 生产环境，性能优化，安全加固
APP_ENV=development

# 应用密钥，用于加密敏感数据（如会话、Token）
# 【重要】生产环境必须使用随机生成的复杂密钥（至少 32 字符）
APP_SECRET_KEY=your-app-secret-key-change-in-production

# 服务器时区设置，影响所有时间相关操作
# 格式: IANA 时区数据库名称
# 示例: Asia/Shanghai, UTC, America/New_York
TIMEZONE=Asia/Shanghai

# 系统默认语言，影响错误消息、文档等
# 格式: ISO 639-1 语言代码 + ISO 3166-1 国家代码
# 示例: zh-CN, en-US
LANGUAGE=zh-CN

# ============================================================
# 应用启动配置（Gunicorn/Uvicorn）
# ============================================================

# 工作进程数，推荐设置为 CPU 核心数的 2-4 倍
# 计算方式: 2-4 × CPU核心数
# 示例: 4 核 CPU 可设置为 8-16
WORKERS=4

# 工作进程类型，决定并发处理方式
# sync: 同步进程，适合 CPU 密集型任务
# gevent: 协程进程，适合 IO 密集型任务（高并发）
# uvicorn.workers.UvicornWorker: ASGI 异步进程
WORKER_CLASS=sync

# 每个工作进程的最大并发连接数
# 建议值: 1000-4000，根据内存和业务调整
WORKER_CONNECTIONS=1000

# HTTP Keep-Alive 超时时间（秒）
# 0: 禁用 Keep-Alive
# 正数: 保持连接的时间，期间可复用 TCP 连接
KEEPALIVE=5

# 请求处理超时时间（秒）
# 超过此时间未完成的请求将被强制终止
TIMEOUT=30

# 优雅停止超时时间（秒）
# 收到停止信号后，等待现有请求完成的最长时间
# 超过此时间仍未完成的请求将被强制终止
GRACEFUL_TIMEOUT=30

# ============================================================
# API 配置
# ============================================================

# API URL 前缀，用于版本隔离和路径区分
# 示例: /api/v1 表示 API 第一版本
# 示例: /api/v2 表示 API 第二版本
API_PREFIX=/api/v1

# 允许的 HTTP 请求方法
# 逗号分隔，多种方法可用
# 注意: OPTIONS 是 CORS 预检请求必需
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# API 文档开关（生产环境建议关闭）
# true: 启用 /docs 和 /redoc 文档页面
# false: 关闭文档，减少暴露接口信息
API_DOCS_ENABLED=true

# Swagger 文档页面路径
API_DOCS_URL=/docs

# OpenAPI JSON 规范文件路径
OPENAPI_URL=/openapi.json

# API 版本控制开关
# true: 启用基于 URL 的版本控制（如 /api/v1, /api/v2）
# false: 单一版本
API_VERSIONING_ENABLED=true

# 默认 API 版本，用于未指定版本时的回退
# 建议始终指向最新稳定版本
API_DEFAULT_VERSION=v1

# ============================================================
# CORS 跨域配置
# ============================================================

# 允许跨域请求的来源地址（逗号分隔）
# 【重要】生产环境必须修改为实际域名
# 示例: https://trai.example.com,https://www.trai.com
# 使用 * 允许所有来源（仅建议开发环境使用）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 是否允许跨域请求携带凭证（Cookie、认证头）
# true: 允许，CORS_ORIGINS 不能设为 *
# false: 不允许，更安全但限制某些功能
CORS_ALLOW_CREDENTIALS=true

# 允许的请求头（* 表示全部，允许自定义头需显式列出）
# 示例: Content-Type,Authorization,X-Request-ID
CORS_ALLOW_HEADERS=*

# 允许的 HTTP 方法
CORS_ALLOW_METHODS=*

# 预检请求（OPTIONS）的缓存时间（秒）
# 此时间内浏览器不会重复发送预检请求
# 600 秒 = 10 分钟
CORS_MAX_AGE=600

# ============================================================
# 数据库配置 (PostgreSQL)
# ============================================================

# 数据库主机地址
DB_HOST=localhost

# 数据库监听端口（PostgreSQL 默认 5432）
DB_PORT=5432

# 数据库名称
DB_NAME=trai_db

# 数据库用户名
DB_USER=trai_user

# 数据库密码
# 【重要】生产环境必须使用强密码
DB_PASSWORD=trai_password_test

# 数据库连接池大小
# 推荐值: CPU 核心数的 2-4 倍
# 影响: 同时可执行的数据库查询数
DB_POOL_SIZE=20

# 连接池最大溢出数量
# 当连接池满时，最多允许创建的额外连接数
# 设置过大可能导致数据库连接数爆满
DB_MAX_OVERFLOW=10

# 从连接池获取连接的超时时间（秒）
# 超过此时间未获取到连接将抛出异常
DB_POOL_TIMEOUT=30

# 连接回收时间（秒）
# 连接空闲超过此时间后会被回收重建
# 防止连接因长时间空闲而被数据库关闭
DB_POOL_RECYCLE=3600

# 是否打印 SQL 语句到日志
# true: 开发环境便于调试
# false: 生产环境提升性能、减少日志量
DB_ECHO=false

# 是否在建立连接前发送 Ping 测试
# true: 检测连接是否有效，避免使用已断开的连接
# 推荐: 始终开启
DB_PRE_PING=true

# 额外的数据库连接参数（JSON 格式）
# 示例: {"connect_timeout": 10, "application_name": "trai"}
# 用于传递数据库驱动特定的配置
DB_CONNECT_ARGS={}

# ============================================================
# 数据库读写分离配置
# ============================================================

# 是否启用读写分离
# true: 启用，读操作使用副本库
# false: 所有操作使用主库
DB_REPLICA_ENABLED=false

# 读副本数据库主机地址
DB_REPLICA_HOST=localhost

# 读副本数据库端口
DB_REPLICA_PORT=5432

# 读副本数据库名称
DB_REPLICA_NAME=trai_db

# 读副本数据库用户名
DB_REPLICA_USER=trai_user

# 读副本数据库密码
DB_REPLICA_PASSWORD=trai_password_test

# ============================================================
# 数据库迁移配置 (Alembic)
# ============================================================

# 是否启用数据库迁移功能
# true: 启用，允许通过 alembic 命令管理数据库结构
# false: 禁用，手动管理数据库结构
ALEMBIC_ENABLED=true

# Alembic 配置文件路径
ALEMBIC_CONFIG=alembic.ini

# ============================================================
# Redis 配置
# ============================================================

# Redis 主机地址
REDIS_HOST=localhost

# Redis 端口（默认 6379）
REDIS_PORT=6379

# Redis 数据库编号（0-15）
# 多个应用应使用不同编号避免数据混淆
REDIS_DB=0

# Redis 认证密码（无密码留空）
REDIS_PASSWORD=

# 是否自动解码 Redis 返回的字节数据
# true: bytes 会自动转为 str，便于处理
# false: 保持 bytes 类型，性能略高
REDIS_DECODE_RESPONSES=true

# 最大连接数
# 建议值: 根据并发量设置，通常 50-100
REDIS_MAX_CONNECTIONS=50

# Socket 操作超时时间（秒）
# 0: 无超时（不推荐）
REDIS_SOCKET_TIMEOUT=5

# Socket 连接超时时间（秒）
# 超过此时间未建立连接将放弃
REDIS_SOCKET_CONNECT_TIMEOUT=5

# 是否启用 TCP Keep-Alive
# true: 保持连接活跃，检测断开的连接
# 推荐: 生产环境开启
REDIS_SOCKET_KEEPALIVES=true

# 健康检查间隔时间（秒）
# 定期检测连接是否有效
REDIS_HEALTH_CHECK_INTERVAL=30

# ============================================================
# Redis 集群配置
# ============================================================

# 是否启用 Redis 集群模式
# true: 启用，连接 Redis Cluster
# false: 单节点模式
REDIS_CLUSTER_ENABLED=false

# Redis Cluster 节点列表（逗号分隔）
# 格式: host:port
# 示例: localhost:7000,localhost:7001,localhost:7002
REDIS_CLUSTER_NODES=localhost:7000,localhost:7001,localhost:7002

# ============================================================
# Redis Sentinel 配置（高可用）
# ============================================================

# 是否启用 Redis Sentinel
# true: 启用，连接 Sentinel 实现故障转移
# false: 单节点模式
REDIS_SENTINEL_ENABLED=false

# Sentinel 监控的主节点名称
# 必须与 Sentinel 配置中的 master 名称一致
REDIS_SENTINEL_MASTER_NAME=trai-master

# Sentinel 节点列表（逗号分隔）
# 格式: host:port
REDIS_SENTINEL_NODES=localhost:26379,localhost:26380,localhost:26381

# Sentinel 认证密码（无密码留空）
REDIS_SENTINEL_PASSWORD=

# ============================================================
# Redis 用途分区（不同用途使用不同数据库）
# ============================================================

# 会话存储使用的数据库编号
REDIS_DB_SESSION=0

# 缓存使用的数据库编号
REDIS_DB_CACHE=1

# 消息队列使用的数据库编号
REDIS_DB_QUEUE=2

# Celery 任务队列使用的数据库编号
REDIS_DB_CELERY=3

# 分布式锁使用的数据库编号
REDIS_DB_LOCK=4

# 限流计数使用的数据库编号
REDIS_DB_RATE_LIMIT=5

# AI 配额计数使用的数据库编号
REDIS_DB_AI_QUOTA=6

# ============================================================
# S3 对象存储配置
# ============================================================

# 存储服务提供商
# minio: 开源对象存储，适合本地开发和私有部署
# aliyun: 阿里云 OSS，公有云，高可用
# aws: 亚马逊 S3，全球覆盖
# 提示: 不同提供商配置不同的 ENDPOINT 和认证信息
S3_PROVIDER=minio

# S3 服务地址（包含协议）
# MinIO 本地开发: http://localhost:9000
# 阿里云 OSS: https://oss-cn-hangzhou.aliyuncs.com
# AWS S3: https://s3.us-east-1.amazonaws.com
S3_ENDPOINT=http://localhost:9000

# S3 Access Key（访问密钥 ID）
# 相当于用户名，用于 API 认证
S3_ACCESS_KEY=minioadmin

# S3 Secret Key（访问密钥密码）
# 【重要】生产环境必须使用随机生成的密钥
S3_SECRET_KEY=minioadmin123

# 存储桶名称
# 用于组织和管理文件，类似于文件夹
S3_BUCKET=trai-media

# 区域代码（影响数据存储位置和访问延迟）
# MinIO: us-east-1（任意）
# 阿里云: oss-cn-hangzhou（杭州）, oss-cn-shanghai（上海）等
# AWS: us-east-1（美东）, ap-northeast-1（日本）等
S3_REGION=us-east-1

# 是否使用 HTTPS 连接
# true: 使用 HTTPS，更安全
# false: 使用 HTTP，仅建议本地开发
S3_SECURE=false

# ============================================================
# S3 安全与限制配置
# ============================================================

# Presigned URL 有效期（秒）
# 【重要】建议不超过 300 秒（5 分钟），防止链接被滥用
# 数值越小越安全，但会影响大文件下载体验
S3_PRESIGNED_URL_EXPIRE_SECONDS=300

# 单个文件最大大小（MB）
# 用于上传前校验，防止恶意大文件
# 建议值: 根据业务需求设置
S3_MAX_FILE_SIZE_MB=500

# 视频文件最大时长（秒）
# 用于上传后校验视频长度
# 3600 秒 = 1 小时
S3_MAX_VIDEO_DURATION_SECONDS=3600

# 禁止上传的文件扩展名（逗号分隔）
# 出于安全考虑，禁止可执行文件上传
S3_FORBIDDEN_EXTENSIONS=exe,sh,py,js,jar,dll,so,bat,cmd,ps1

# ============================================================
# LLM 大模型配置
# ============================================================

# LLM 服务提供商选择
# openai: OpenAI GPT 系列
# azure: Azure OpenAI Service
# anthropic: Anthropic Claude 系列
# modelscope: 魔塔社区（国产，免费额度）
# local: 本地部署（如 Ollama）
LLM_PROVIDER=modelscope

# OpenAI API 密钥
# 从 https://platform.openai.com 获取
OPENAI_API_KEY=sk-test-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API 基础地址
# 官方: https://api.openai.com/v1
# 代理/第三方: 自行部署的代理地址
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 模型名称
# gpt-4o: 最新多模态模型，支持图像
# gpt-4-turbo: 快速版 GPT-4
# gpt-3.5-turbo: 低价快速
OPENAI_MODEL=gpt-4o

# OpenAI 单次请求最大 Token 数
# 影响单次对话长度
# 最大支持 128k tokens（GPT-4 Turbo）
OPENAI_MAX_TOKENS=4096

# OpenAI 生成温度（0-2）
# 0: 确定输出，更适合任务执行
# 0.7: 平衡创造性和准确性
# 1.5-2: 创造性输出，可能不稳定
OPENAI_TEMPERATURE=0.7

# OpenAI API 请求超时时间（秒）
# 复杂任务可能需要较长时间
OPENAI_TIMEOUT=120

# ============================================================
# 魔塔社区 ModelScope 大模型配置（推荐国内用户）
# ============================================================

# 是否启用魔塔社区
# true: 使用魔塔社区模型
# false: 使用其他配置的模型
MODELSCOPE_ENABLED=true

# 魔塔社区 API 地址
MODELSCOPE_API_BASE=https://api.modelscope.cn/v1

# 魔塔社区 API 密钥
# 从 https://modelscope.cn 获取
MODELSCOPE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API 请求超时时间（秒）
MODELSCOPE_TIMEOUT=120

# 默认对话模型（用于未指定模型时）
MODELSCOPE_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct

# 默认最大 Token 数
MODELSCOPE_DEFAULT_MAX_TOKENS=4096

# 默认温度参数
MODELSCOPE_DEFAULT_TEMPERATURE=0.7

# 默认 Top-P（核采样参数）
# 控制模型考虑的 Token 范围
MODELSCOPE_DEFAULT_TOP_P=0.9

# 默认 Top-K（候选 Token 数）
# 每次只考虑概率最高的 K 个 Token
MODELSCOPE_DEFAULT_TOP_K=50

# 可用的对话模型列表（逗号分隔）
MODELSCOPE_CHAT_MODELS=Qwen/Qwen2.5-7B-Instruct,Qwen/Qwen2.5-14B-Instruct,Qwen/Qwen2.5-72B-Instruct

# 默认使用的对话模型
MODELSCOPE_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct

# 可用的图像理解模型列表
MODELSCOPE_VISION_MODELS=Qwen/Qwen2-VL-7B-Instruct,Qwen/Qwen2-VL-72B-Instruct

# 默认使用的图像理解模型
MODELSCOPE_VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct

# 可用的嵌入模型列表（用于文本向量化）
MODELSCOPE_EMBEDDING_MODELS=sentence-transformers paraphrase-multilingual-MiniLM-L12-v2

# 默认使用的嵌入模型
MODELSCOPE_EMBEDDING_MODEL=sentence-transformers paraphrase-multilingual-MiniLM-L12-v2

# 可用的代码模型列表
MODELSCOPE_CODE_MODELS=Qwen/CodeQwen1.5-7B-Chat,Qwen/CodeQwen1.5-14B-Chat

# 默认使用的代码模型
MODELSCOPE_CODE_MODEL=Qwen/CodeQwen1.5-7B-Chat

# ============================================================
# 图像生成配置
# ============================================================

# 图像生成服务提供商
# modelscope: 魔塔社区
# openai: OpenAI DALL-E
# stability: Stability AI
# midjourney: Midjourney（需配合第三方）
IMAGE_PROVIDER=modelscope

# 魔塔社区图像生成模型
# FLUX.1-dev: 高质量图像生成
MODELSCOPE_IMAGE_MODEL=AI-ModelScope/FLUX.1-dev

# 生成迭代步数（影响质量和速度）
# 数值越大质量越高，速度越慢
# 建议值: 20-50
MODELSCOPE_IMAGE_STEPS=30

# 生成图像宽度（像素）
MODELSCOPE_IMAGE_WIDTH=1024

# 生成图像高度（像素）
MODELSCOPE_IMAGE_HEIGHT=1024

# 随机种子（-1 表示随机）
# 使用相同种子可以获得可复现的结果
MODELSCOPE_IMAGE_SEED=-1

# ============================================================
# 视频生成配置
# ============================================================

# 视频生成服务提供商
# modelscope: 魔塔社区
# openai: OpenAI Sora
# runwayml: Runway ML
# pika: Pika Labs
# kling: 阿里云通义万相
VIDEO_PROVIDER=modelscope

# 魔塔社区视频生成模型
MODELSCOPE_VIDEO_MODEL=I2VGen-XL/I2VGenXL_HD

# 视频时长（秒）
MODELSCOPE_VIDEO_DURATION=5

# 视频帧率（fps）
# 24: 电影标准
# 30: 通用
# 60: 高清流畅
MODELSCOPE_VIDEO_FPS=24

# 视频分辨率
# 480p: 标清
# 720p: 高清
# 1080p: 全高清
MODELSCOPE_VIDEO_RESOLUTION=720p

# ============================================================
# 音频合成配置（TTS - Text to Speech）
# ============================================================

# 语音合成服务提供商
# modelscope: 魔塔社区
# openai: OpenAI TTS
# elevenlabs: ElevenLabs（高质量）
# azure_tts: Azure 语音服务
AUDIO_PROVIDER=modelscope

# 魔塔社区 TTS 模型名称
MODELSCOPE_TTS_MODEL=speech_sambert-hifigan_tts_zhidapeechd院士_好 clinicspeech_sambert-hifigan_tts_zhidaSpeechD-zhida-speech

# 音频采样率（Hz）
# 16000: 通用
# 44100: CD 音质
# 越高音质越好，但文件越大
MODELSCOPE_TTS_SAMPLE_RATE=16000

# 语速（1.0 为正常速度）
# 0.5: 0.5 倍速
# 2.0: 2 倍速
MODELSCOPE_TTS_SPEED=1.0

# 音量（1.0 为正常音量）
# 0.0: 静音
# 2.0: 2 倍音量
MODELSCOPE_TTS_VOLUME=1.0

# 音调（0 为正常音调）
# 正数: 音调升高（变尖）
# 负数: 音调降低（变沉）
MODELSCOPE_TTS_PITCH=0

# ============================================================
# 语音识别配置（ASR - Automatic Speech Recognition）
# ============================================================

# 语音识别服务提供商
# modelscope: 魔塔社区（SenseVoice）
# openai: OpenAI Whisper
# azure_stt: Azure 语音识别
TRANSCRIPTION_PROVIDER=modelscope

# 魔塔社区 ASR 模型
# sensevoice: 通用语音识别模型
MODELSCOPE_ASR_MODEL=sensevoice

# 识别语言设置
# auto: 自动检测语言
# zh: 中文
# en: 英文
# ja: 日文
MODELSCOPE_ASR_LANGUAGE=auto

# 是否启用逆文本正则化（ITN）
# true: 将数字、日期等转换为文字
# 示例: "2024年1月1日" 而非 "2024/1/1"
MODELSCOPE_ASR_USE_ITN=true

# 语音识别超时时间（秒）
MODELSCOPE_ASR_TIMEOUT=60

# ============================================================
# AI 内容审核配置
# ============================================================

# 是否启用 AI 内容审核
# true: 启用，对用户内容进行安全审核
# false: 禁用，不审核
MODERATION_ENABLED=true

# 内容审核服务提供商
# modelscope: 魔塔社区视觉模型
# openai: OpenAI Moderation
# aliyun: 阿里云内容安全
# tencent: 腾讯云内容审核
MODERATION_PROVIDER=modelscope

# 魔塔社区审核模型
MODELSCOPE_MODERATION_MODEL=Qwen/Qwen2-VL-7B-Instruct

# 审核置信度阈值（0-1）
# 低于此值的内容将被判定为违规
# 数值越低越严格，误杀率可能增加
# 建议值: 0.6-0.8
MODELSCOPE_MODERATION_CONFIDENCE=0.75

# 全局审核阈值
MODERATION_THRESHOLD=0.7

# ============================================================
# 企业微信 SSO 配置
# ============================================================

# 是否启用企业微信
# true: 启用企业微信登录和集成
# false: 禁用
WECOM_ENABLED=true

# 企业 ID（用于标识企业）
# 在企业微信管理后台 -> 我的企业 查看
WECOM_CORP_ID=ww1234567890abcdef

# 应用 Agent ID
# 在企业微信管理后台 -> 应用管理 查看
WECOM_AGENT_ID=1000001

# 应用 Secret
# 【重要】生产环境必须保护，不要暴露在前端
WECOM_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 回调验证 Token
# 用于验证回调请求来源
# 建议使用随机字符串，至少 32 字符
WECOM_CALLBACK_TOKEN=abcdefghijklmnopqrstuvwxyz123456

# 回调 AES 密钥
# 用于加密回调消息
# 必须为 43 位字符
WECOM_CALLBACK_AES_KEY=abcdefghijklmnopqrstuvwxyz1234567890ABC

# OAuth 回调地址
# 用户授权后跳转回本系统的地址
# 必须与企业在企业微信后台配置的一致
WECOM_REDIRECT_URI=http://localhost:5666/auth/wecom/callback

# 企业微信 API 基础地址
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com

# API 请求超时时间（秒）
WECOM_API_TIMEOUT=30

# API 最大重试次数
WECOM_API_MAX_RETRIES=3

# OAuth 授权范围
# snsapi_base: 仅获取用户 UserID
# snsapi_userinfo: 获取用户姓名、头像等信息
WECOM_LOGIN_SCOPE=snsapi_base

# 登录状态有效期（秒）
# 用户在授权页面停留超过此时间需重新授权
WECOM_LOGIN_STATE_EXPIRE=600

# 是否自动绑定已有账号
# true: 企业微信用户自动绑定同用户名/邮箱的已有账号
# false: 必须手动绑定或注册新账号
WECOM_LOGIN_AUTO_BIND=false

# ============================================================
# 企业微信用户同步配置
# ============================================================

# 是否启用用户同步
# true: 定期从企业微信同步用户到本地
# false: 不同步
WECOM_USER_SYNC_ENABLED=true

# 同步方式
# full: 全量同步（每次同步所有用户）
# incremental: 增量同步（仅同步变更的用户）
# full_on_first: 首次全量，后续增量
WECOM_USER_SYNC_MODE=incremental

# 同步周期（Cron 表达式）
# 0 0 * * *: 每天凌晨
# 0 */4 * * *: 每 4 小时
# 0 */6 * * *: 每 6 小时
# 参考: https://crontab.guru/
WECOM_USER_SYNC_CRON=0 0 * * *

# 首次同步是否自动执行
# true: 服务启动时自动执行首次同步
# false: 手动触发首次同步
WECOM_USER_SYNC_AUTO_FIRST=true

# 要同步的部门 ID 列表（逗号分隔）
# 空: 同步全部部门
# 示例: 1,2,3: 只同步这 3 个部门
WECOM_USER_SYNC_DEPARTMENT_IDS=

# 是否包含离职员工
# true: 同步已离职员工（标记为禁用）
# false: 不同步离职员工
WECOM_USER_SYNC_INCLUDE_INACTIVE=false

# 离职员工处理方式
# disable: 禁用账号（保留数据）
# delete: 删除账号
# freeze: 冻结账号
WECOM_USER_SYNC_INACTIVE_ACTION=disable

# 用户字段映射配置
# 定义企业微信字段与本地字段的对应关系
WECOM_USER_SYNC_FIELD_USERID=userid
WECOM_USER_SYNC_FIELD_NAME=name
WECOM_USER_SYNC_FIELD_DEPARTMENT=department
WECOM_USER_SYNC_FIELD_POSITION=position
WECOM_USER_SYNC_FIELD_MOBILE=mobile
WECOM_USER_SYNC_FIELD_EMAIL=email
WECOM_USER_SYNC_FIELD_AVATAR=avatar

# 是否自动创建部门
# true: 企业微信的部门在本地自动创建
# false: 部门必须手动创建
WECOM_USER_SYNC_AUTO_CREATE_DEPT=true

# 同步冲突处理策略
# wecom: 以企业微信数据为准
# local: 以本地数据为准（保留本地修改）
# merge: 合并策略（取两者的并集）
WECOM_USER_SYNC_CONFLICT_STRATEGY=wecom

# 是否同步用户头像
# true: 下载并保存用户头像
# false: 不同步头像
WECOM_USER_SYNC_AVATAR=true

# 头像下载超时（秒）
WECOM_USER_SYNC_AVATAR_TIMEOUT=30

# 同步失败重试次数
WECOM_USER_SYNC_MAX_RETRIES=3

# 同步失败重试间隔（秒）
WECOM_USER_SYNC_RETRY_DELAY=60

# 同步锁过期时间（秒）
# 防止多个进程同时同步
WECOM_USER_SYNC_LOCK_EXPIRE=3600

# 是否记录同步详细日志
# true: 记录每次同步的详细信息
# false: 只记录概要
WECOM_USER_SYNC_DETAILED_LOG=false

# 同步超时时间（秒）
# 超过此时间未完成则中断同步
WECOM_USER_SYNC_TIMEOUT=1800

# 是否启用同步事件通知
# true: 同步完成后发送通知
# false: 不发送
WECOM_USER_SYNC_NOTIFY=false

# ============================================================
# 钉钉 SSO 配置
# ============================================================

# 是否启用钉钉
# true: 启用钉钉登录和集成
# false: 禁用
DINGTALK_ENABLED=false

# 钉钉应用 App ID
DINGTALK_APP_ID=dingoaxxxxxxxxxxxxxxxxxx

# 钉钉应用 App Secret
# 【重要】生产环境必须保护
DINGTALK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 回调验证 Token
DINGTALK_CALLBACK_TOKEN=

# 回调 AES 密钥
DINGTALK_CALLBACK_AES_KEY=

# OAuth 回调地址
DINGTALK_REDIRECT_URI=http://localhost:5666/auth/dingtalk/callback

# 钉钉 API 基础地址
DINGTALK_API_BASE_URL=https://api.dingtalk.com

# API 请求超时时间（秒）
DINGTALK_API_TIMEOUT=30

# OAuth 授权范围
# corpid: 仅获取企业 ID
# userid: 获取用户 ID
DINGTALK_LOGIN_SCOPE=corpid

# 是否自动绑定已有账号
DINGTALK_LOGIN_AUTO_BIND=false

# ============================================================
# 飞书 SSO 配置
# ============================================================

# 是否启用飞书
# true: 启用飞书登录和集成
# false: 禁用
FEISHU_ENABLED=false

# 飞书应用 App ID
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx

# 飞书应用 App Secret
# 【重要】生产环境必须保护
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 回调验证 Token
FEISHU_CALLBACK_TOKEN=

# 回调 AES 密钥
FEISHU_CALLBACK_AES_KEY=

# OAuth 回调地址
FEISHU_REDIRECT_URI=http://localhost:5666/auth/feishu/callback

# 飞书 API 基础地址
FEISHU_API_BASE_URL=https://open.feishu.cn

# API 请求超时时间（秒）
FEISHU_API_TIMEOUT=30

# OAuth 授权范围
# tenant: 获取租户信息
# user: 获取用户信息
FEISHU_LOGIN_SCOPE=tenant

# 是否自动绑定已有账号
FEISHU_LOGIN_AUTO_BIND=false

# ============================================================
# JWT 认证配置
# ============================================================

# JWT 签名密钥
# 【重要】生产环境必须使用随机生成的复杂密钥（至少 32 字符）
# 用于签名和验证 Token 真实性
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# JWT 签名算法
# HS256: 对称加密，速度快（推荐）
# RS256: 非对称加密，安全性更高
# HS384, HS512: 更安全的对称加密
JWT_ALGORITHM=HS256

# Access Token 有效期（分钟）
# 建议值: 15-60 分钟
# 太长: 安全风险增加
# 太短: 用户频繁需要登录
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh Token 有效期（天）
# 建议值: 7-30 天
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Token 前缀
# 通常为 "Bearer"，用于 Authorization 头
# 格式: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
JWT_TOKEN_PREFIX=Bearer

# 请求头名称
# 用于传递 Token
JWT_HEADER_NAME=Authorization

# 身份声明字段
# 指定 Token 中哪个字段存储用户 ID
# sub: Subject，通常存放用户 ID
JWT_IDENTITY_CLAIM=sub

# 时间偏移容差（秒）
# 允许 Token 时间误差在此范围内
# 用于解决服务器时间不同步问题
JWT_LEEWAY=10

# ============================================================
# JWT 刷新与安全配置
# ============================================================

# Refresh Token 刷新时是否轮换
# true: 每次刷新生成新的 Refresh Token（更安全）
# false: 复用相同 Token（可能被窃取后长期使用）
JWT_REFRESH_TOKEN_ROTATION=true

# 是否允许复用 Refresh Token
# true: 允许多次使用（不安全）
# false: 每个 Token 只能使用一次
JWT_REFRESH_TOKEN_REUSE=false

# ============================================================
# Token 黑名单配置
# ============================================================

# 是否启用 Token 黑名单
# true: 启用，退出登录后 Token 立即失效
# false: 禁用，Token 只能等待自然过期
JWT_BLACKLIST_ENABLED=true

# 黑名单存储后端
# redis: 内存存储，速度快（推荐）
# database: 数据库存储，持久化
JWT_BLACKLIST_STORAGE=redis

# 黑名单 Key 前缀
JWT_BLACKLIST_PREFIX=jti_blacklist

# ============================================================
# 双因素认证配置
# ============================================================

# 是否要求双因素认证
# true: 所有用户必须启用 2FA
# false: 可选启用
JWT_2FA_REQUIRED=false

# 双因素认证颁发者
JWT_2FA_ISSUER=TRAI

# ============================================================
# 会话配置
# ============================================================

# 会话密钥
# 【重要】用于加密会话数据
SESSION_SECRET_KEY=session-secret-key-change-in-production

# 会话有效期（秒）
# 86400 秒 = 24 小时
SESSION_EXPIRE_SECONDS=86400

# 会话 Cookie 名称
SESSION_COOKIE_NAME=trai_session

# Cookie 是否仅通过 HTTPS 传输
# 【重要】生产环境必须设为 true
SESSION_COOKIE_SECURE=false

# Cookie 是否禁止 JavaScript 访问
# true: 防止 XSS 攻击读取 Cookie（推荐）
# false: 允许 JS 访问
SESSION_COOKIE_HTTPONLY=true

# Cookie SameSite 属性
# strict: 完全禁止跨站发送
# lax: 大多数情况禁止（推荐）
# none: 允许跨站发送（需要配合 Secure）
SESSION_COOKIE_SAMESITE=lax

# ============================================================
# 会话存储配置
# ============================================================

# 会话存储后端
# redis: Redis 存储，性能高（推荐）
# database: 数据库存储，持久化
# memory: 内存存储，仅适合单进程
SESSION_BACKEND=redis

# 会话 Redis 数据库编号
SESSION_REDIS_DB=0

# 会话 Key 前缀
SESSION_KEY_PREFIX=trai:session:

# 是否在每次请求时延长会话有效期
# true: 用户活跃时会话不会过期
# false: 会话按固定时间过期
SESSION_EXTEND_ON_PY_REQUEST=true

# 是否为永久会话
# true: 会话不过期（需配合 Cookie 持久化）
# false: 按 expire_seconds 过期
SESSION_PERMANENT=false

# ============================================================
# CSRF 保护配置
# ============================================================

# 是否启用 CSRF 保护
# true: 启用，防止跨站请求伪造（推荐）
# false: 禁用（不推荐）
CSRF_ENABLED=true

# CSRF Token 传递位置
# header: 通过请求头传递
# cookie: 通过 Cookie 传递
# both: 同时支持
CSRF_TOKEN_LOCATION=header

# CSRF Token 请求头名称
CSRF_HEADER_NAME=X-CSRF-Token

# CSRF Cookie 名称
CSRF_COOKIE_NAME=csrf_token

# CSRF Cookie Secure 属性
CSRF_COOKIE_SECURE=false

# CSRF Cookie HttpOnly 属性
CSRF_COOKIE_HTTPONLY=false

# CSRF Cookie SameSite 属性
CSRF_COOKIE_SAMESITE=lax

# ============================================================
# 权限与访问控制配置
# ============================================================

# 是否启用权限控制
# true: 启用，基于角色的权限控制
# false: 禁用，所有用户拥有全部权限
PERMISSION_ENABLED=true

# 权限控制模式
# rbac: 基于角色的访问控制（RBAC）
# abac: 基于属性的访问控制（ABAC）
# hybrid: 混合模式
PERMISSION_MODE=rbac

# 默认角色（用户注册后的默认角色）
# none: 无角色，需要管理员分配
# user: 普通用户
# viewer: 只读用户
PERMISSION_DEFAULT_ROLE=user

# 角色列表定义
PERMISSION_ROLES=admin,manager,user,viewer,guest

# 超级管理员角色
# 此角色的用户拥有所有权限
PERMISSION_SUPER_ADMIN_ROLE=admin

# ============================================================
# 权限验证配置
# ============================================================

# 是否启用接口级别权限验证
# true: 每个 API 都验证权限
# false: 仅特定接口验证
PERMISSION_API_CHECK=true

# 是否启用数据级别权限验证
# true: 验证用户对数据的访问权限
# false: 不验证
PERMISSION_DATA_CHECK=true

# 权限验证失败时的默认行为
# reject: 直接拒绝请求
# redirect: 重定向到无权限页面
# fallback: 使用降级策略
PERMISSION_DENIED_ACTION=reject

# 权限验证缓存时间（秒）
# 减少重复验证，提升性能
PERMISSION_CACHE_TTL=300

# 权限验证缓存大小
# 最大缓存的权限条目数
PERMISSION_CACHE_MAX_SIZE=10000

# ============================================================
# 资源权限配置
# ============================================================

# 资源类型列表
PERMISSION_RESOURCE_TYPES=user,role,department,activity,ai_task,file,setting

# 用户资源权限
PERMISSION_RESOURCE_USER_CREATE=admin,manager
PERMISSION_RESOURCE_USER_READ=user,manager,admin
PERMISSION_RESOURCE_USER_UPDATE=admin,manager
PERMISSION_RESOURCE_USER_DELETE=admin
PERMISSION_RESOURCE_USER_LIST=user,manager,admin

# 角色资源权限
PERMISSION_RESOURCE_ROLE_CREATE=admin
PERMISSION_RESOURCE_ROLE_READ=admin,manager
PERMISSION_RESOURCE_ROLE_UPDATE=admin
PERMISSION_RESOURCE_ROLE_DELETE=admin
PERMISSION_RESOURCE_ROLE_LIST=admin,manager

# 部门资源权限
PERMISSION_RESOURCE_DEPT_CREATE=admin,manager
PERMISSION_RESOURCE_DEPT_READ=user,manager,admin
PERMISSION_RESOURCE_DEPT_UPDATE=admin,manager
PERMISSION_RESOURCE_DEPT_DELETE=admin

# 活动资源权限
PERMISSION_RESOURCE_ACTIVITY_CREATE=user,manager,admin
PERMISSION_RESOURCE_ACTIVITY_READ=member,user,manager,admin
PERMISSION_RESOURCE_ACTIVITY_UPDATE=owner,manager,admin
PERMISSION_RESOURCE_ACTIVITY_DELETE=owner,manager,admin

# AI 任务资源权限
PERMISSION_RESOURCE_AI_CREATE=user,manager,admin
PERMISSION_RESOURCE_AI_READ=owner,member,manager,admin
PERMISSION_RESOURCE_AI_CANCEL=owner,manager,admin
PERMISSION_RESOURCE_AI_LIST=user,manager,admin

# 文件资源权限
PERMISSION_RESOURCE_FILE_UPLOAD=user,manager,admin
PERMISSION_RESOURCE_FILE_DOWNLOAD=owner,member,manager,admin
PERMISSION_RESOURCE_FILE_DELETE=owner,manager,admin
PERMISSION_RESOURCE_FILE_LIST=user,manager,admin

# 设置资源权限
PERMISSION_RESOURCE_SETTING_READ=user,manager,admin
PERMISSION_RESOURCE_SETTING_UPDATE=admin,manager
PERMISSION_RESOURCE_SETTING_LIST=admin

# ============================================================
# 活动成员权限配置
# ============================================================

# 活动成员角色列表
PERMISSION_ACTIVITY_ROLES=owner,admin,moderator,member,guest

# 活动所有者角色
# 创建活动的用户
PERMISSION_ACTIVITY_OWNER=owner

# 活动管理员角色
# 可以管理活动设置和成员
PERMISSION_ACTIVITY_ADMIN=admin

# 活动版主角色
# 可以审核内容和管理普通成员
PERMISSION_ACTIVITY_MODERATOR=moderator

# 活动普通成员
# 可以参与活动
PERMISSION_ACTIVITY_MEMBER=member

# 活动访客
# 只能查看公开内容
PERMISSION_ACTIVITY_GUEST=guest

# 活动权限继承策略
# inherit: 继承活动权限
# exclusive: 独立权限（与活动权限独立）
PERMISSION_ACTIVITY_INHERITANCE=inherit

# ============================================================
# 字段级权限配置
# ============================================================

# 是否启用字段级别权限控制
# true: 可以控制哪些角色可以看到哪些字段
# false: 只能控制资源级别
PERMISSION_FIELD_ENABLED=false

# 字段权限配置示例
# 格式: 资源.字段=可见角色列表
PERMISSION_FIELD_USER_PASSWORD=admin
PERMISSION_FIELD_USER_EMAIL=admin,manager,user
PERMISSION_FIELD_USER_PHONE=admin,manager

# ============================================================
# API 权限配置
# ============================================================

# API 权限白名单（不需要权限验证的路径）
# 格式: /path1,/path2/*
PERMISSION_API_WHITELIST=/health,/metrics,/docs,/openapi.json,/auth/login,/auth/register

# API 权限黑名单（永远不允许访问的路径）
PERMISSION_API_BLACKLIST=

# 是否记录权限验证日志
# true: 记录每次权限验证
# false: 不记录
PERMISSION_LOG_ENABLED=true

# 权限日志级别
# info: 记录所有验证
# warning: 只记录拒绝
# debug: 记录详细信息
PERMISSION_LOG_LEVEL=info

# ============================================================
# 部门层级权限配置
# ============================================================

# 是否启用部门层级权限
# true: 子部门继承父部门权限
# false: 部门权限独立
PERMISSION_DEPT_HIERARCHY=true

# 部门数据隔离策略
# all: 可以访问所有下级部门数据
# direct: 只能访问直属下级部门数据
# none: 不限制
PERMISSION_DEPT_DATA_SCOPE=all

# ============================================================
# 委托权限配置
# ============================================================

# 是否允许权限委托
# true: 用户可以将权限委托给其他人
# false: 不允许
PERMISSION_DELEGATION_ENABLED=false

# 委托权限有效期（天）
PERMISSION_DELEGATION_EXPIRE_DAYS=7

# 委托权限最大数量
# 一个人最多同时拥有的委托权限数
PERMISSION_DELEGATION_MAX_COUNT=5

# ============================================================
# 审计与合规配置
# ============================================================

# 是否记录权限变更审计
# true: 记录所有权限变更
# false: 不记录
PERMISSION_AUDIT_ENABLED=true

# 审计日志保留天数
PERMISSION_AUDIT_RETENTION_DAYS=365

# 是否启用异常行为检测
# true: 检测权限异常使用
# false: 不检测
PERMISSION_ANOMALY_DETECTION=false

# 异常行为检测阈值
# 超过此数量的权限拒绝视为异常
PERMISSION_ANOMALY_THRESHOLD=10

# ============================================================
# 限流配置
# ============================================================

# 是否启用限流
# true: 启用，保护系统免受滥用
# false: 禁用（不推荐）
RATE_LIMIT_ENABLED=true

# 限流数据存储后端
# redis: Redis 存储，分布式支持（推荐）
# memory: 内存存储，仅单进程
RATE_LIMIT_STORAGE=redis

# 限流 Redis 连接地址
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/5

# 限流 Key 前缀
RATE_LIMIT_STORAGE_PREFIX=ratelimit:

# 下载限流（每分钟，每 IP）
# 防止大量下载消耗带宽
RATE_LIMIT_DOWNLOAD_PER_MINUTE=60

# 上传限流（每分钟，每 IP）
# 防止大文件上传攻击
RATE_LIMIT_UPLOAD_PER_MINUTE=30

# API 通用限流（每分钟，每 IP）
# 防止 API 滥用
RATE_LIMIT_API_PER_MINUTE=100

# AI 任务限流（每小时，每用户）
# 防止 AI 资源被过度使用
RATE_LIMIT_AI_TASK_PER_HOUR=50

# 登录限流（每分钟，每 IP）
# 防止暴力破解
RATE_LIMIT_LOGIN_PER_MINUTE=5

# 注册限流（每分钟，每 IP）
# 防止批量注册
RATE_LIMIT_REGISTER_PER_MINUTE=3

# 短信验证码限流（每分钟，每 IP/手机号）
# 防止短信轰炸
RATE_LIMIT_SMS_PER_MINUTE=5

# 搜索限流（每分钟，每用户）
# 防止搜索滥用
RATE_LIMIT_SEARCH_PER_MINUTE=30

# ============================================================
# 限流响应配置
# ============================================================

# 是否在响应头中包含限流信息
# true: 返回 X-RateLimit-* 头
# false: 不返回
RATE_LIMIT_HEADERS_ENABLED=true

# 限流上限 Header 名称
RATE_LIMIT_HEADERS_LIMIT=X-RateLimit-Limit

# 剩余请求数 Header 名称
RATE_LIMIT_HEADERS_REMAINING=X-RateLimit-Remaining

# 重置时间戳 Header 名称
RATE_LIMIT_HEADERS_RESET=X-RateLimit-Reset

# 限流策略
# fixed_window: 固定窗口，简单但可能有边界问题
# sliding_window: 滑动窗口，更精确
# token_bucket: 令牌桶，流量平滑
RATE_LIMIT_STRATEGY=fixed_window

# ============================================================
# AI 配额配置
# ============================================================

# 是否启用 AI 配额控制
# true: 启用，用户有额度和使用限制
# false: 禁用，无限制使用
AI_QUOTA_ENABLED=true

# 配额存储后端
# redis: Redis 存储，性能高（推荐）
# database: 数据库存储，持久化
AI_QUOTA_STORAGE=redis

# 配额 Key 前缀
AI_QUOTA_STORAGE_PREFIX=ai_quota:

# 图像生成月度配额（次/月）
# 普通用户每月可用次数
AI_QUOTA_IMAGE_PER_MONTH=100

# 视频生成月度配额（次/月）
AI_QUOTA_VIDEO_PER_MONTH=10

# 对话月度配额（次/月）
AI_QUOTA_CHAT_PER_MONTH=1000

# 音频合成月度配额（分钟/月）
AI_QUOTA_AUDIO_PER_MONTH=60

# 语音识别月度配额（分钟/月）
AI_QUOTA_TRANSCRIPTION_PER_MONTH=300

# 管理员是否有无限配额
# true: 管理员不受配额限制
# false: 管理员也有配额限制
AI_QUOTA_ADMIN_UNLIMITED=true

# 配额超限处理策略
# reject: 直接拒绝请求
# queue: 排队等待
# upgrade: 提示用户升级
AI_QUOTA_OVERFLOW_STRATEGY=reject

# 配额重置周期
# monthly: 每月重置
# weekly: 每周重置
# daily: 每日重置
AI_QUOTA_RESET_PERIOD=monthly

# 配额预警阈值（百分比）
# 当使用量达到此比例时发送警告通知
AI_QUOTA_WARNING_THRESHOLD=80

# ============================================================
# 配额共享配置
# ============================================================

# 是否启用配额共享
# true: 团队/企业成员共享配额池
# false: 每人独立配额
AI_QUOTA_SHARING_ENABLED=false

# 是否启用团队配额池
# true: 使用团队总配额
# false: 使用个人配额
AI_QUOTA_TEAM_POOL_ENABLED=false

# 团队 ID
AI_QUOTA_TEAM_ID=

# 是否记录配额使用日志
AI_QUOTA_LOG_ENABLED=true

# 配额日志保留天数
AI_QUOTA_LOG_RETENTION_DAYS=90

# ============================================================
# 消息队列配置 (Celery)
# ============================================================

# 是否启用 Celery 异步任务
# true: 启用，耗时任务异步执行
# false: 禁用，所有任务同步执行
CELERY_ENABLED=false

# Broker 类型
# redis: Redis 消息队列（推荐）
# rabbitmq: RabbitMQ（功能更强）
# sqs: AWS SQS（云服务）
CELERY_BROKER_TYPE=redis

# Redis Broker 连接地址
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery 结果后端地址
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# 任务序列化方式
# json: JSON 格式，兼容性最好
# pickle: Python pickle，高效但有安全风险
# msgpack: 高效二进制格式
CELERY_TASK_SERIALIZER=json

# 结果序列化方式
CELERY_RESULT_SERIALIZER=json

# 接受的序列化格式
CELERY_ACCEPT_CONTENT=json

# Celery 时区（影响定时任务执行时间）
CELERY_TIMEZONE=Asia/Shanghai

# 是否使用 UTC 时间
CELERY_ENABLE_UTC=true

# 是否追踪任务状态
# true: 可以查询任务状态
# false: 任务执行即忘，不追踪
CELERY_TASK_TRACK_STARTED=true

# ============================================================
# Celery 任务限制配置
# ============================================================

# 任务硬超时时间（秒）
# 超过此时间任务将被强制终止
CELERY_TASK_TIME_LIMIT=3600

# 任务软超时时间（秒）
# 超过此时间发送警告，可自行处理
CELERY_TASK_SOFT_TIME_LIMIT=3300

# ============================================================
# Celery 队列配置
# ============================================================

# 可用队列列表
# celery: 普通队列
# celery_high: 高优先级队列
# celery_low: 低优先级队列
CELERY_TASK_QUEUES=celery,celery_high,celery_low

# 默认队列（未指定时使用）
CELERY_TASK_DEFAULT_QUEUE=celery

# 默认交换机名称
CELERY_TASK_DEFAULT_EXCHANGE=celery

# 默认路由键
CELERY_TASK_DEFAULT_ROUTING_KEY=celery

# ============================================================
# Celery Worker 配置
# ============================================================

# 用户优先级是否反转
# true: 数字越大优先级越高
# false: 数字越小优先级越高
CELERY_TASK_INVERT_USER_PRIO=true

# Worker 预取任务数
# 建议值: CPU 核心数 × 4
# 影响并发处理能力
CELERY_WORKER_PREFETCH_MULTIPLIER=4

# Worker 最大任务数
# 超过此数后 Worker 会重启（防止内存泄漏）
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# ============================================================
# Celery 结果配置
# ============================================================

# 结果过期时间（秒）
# 超过此时间的结果会被删除
CELERY_RESULT_EXPIRES=3600

# 是否持久化结果
# true: 结果存入后端
# false: 结果不存储
CELERY_RESULT_PERSISTENT=true

# 结果压缩方式
# gzip: 压缩存储
# 无: 不压缩
CELERY_RESULT_COMPRESSION=gzip

# ============================================================
# Celery 定时任务配置
# ============================================================

# Beat 调度器
# celery.beat:PersistentScheduler: 基于文件的持久化调度器
CELERY_BEAT_SCHEDULER=celery.beat:PersistentScheduler

# Beat 同步周期（秒）
# 定期将调度器状态同步到磁盘
CELERY_BEAT_SYNC_EVERY=3

# ============================================================
# Celery 监控配置
# ============================================================

# 是否发送任务事件
# true: 允许监控工具追踪任务
# false: 禁用事件
CELERY_SEND_EVENTS=true

# 是否发送任务提交事件
CELERY_SEND_TASK_SENT_EVENT=true

# 任务错误时是否发送邮件通知
CELERY_SEND_TASK_ERROR_EMAILS=false

# Worker 是否发送任务事件
CELERY_WORKER_SEND_TASK_EVENTS=true

# ============================================================
# 日志配置
# ============================================================

# 全局日志级别
# DEBUG: 最详细，包含调试信息
# INFO: 正常运行信息
# WARNING: 警告信息
# ERROR: 错误信息
# CRITICAL: 严重错误
# 建议: 开发环境 DEBUG，生产环境 INFO
LOG_LEVEL=INFO

# 日志根目录（相对于 backend 根目录）
# 所有日志文件将存放在此目录下
LOG_ROOT_PATH=./logs

# 是否启用文件日志
# true: 日志写入文件
# false: 仅输出到控制台
LOG_FILE_ENABLED=true

# 日志文件保留天数
# 超过此时间的日志文件将被删除
LOG_FILE_RETENTION=30days

# 日志文件压缩方式
# zip: ZIP 压缩（推荐，压缩率高）
# gzip: GZIP 压缩
# 无: 不压缩
LOG_FILE_COMPRESSION=zip

# ============================================================
# 日志文件分离配置
# ============================================================

# 应用主日志文件路径
# 记录应用程序正常运行日志
LOG_FILE_APP=logs/app.log

# 错误日志文件路径
# 仅记录 ERROR 和 CRITICAL 级别日志
LOG_FILE_ERROR=logs/error.log

# 访问日志文件路径
# 记录所有 HTTP 请求
LOG_FILE_ACCESS=logs/access.log

# 安全日志文件路径
# 记录登录、权限等安全相关事件
LOG_FILE_SECURITY=logs/security.log

# 审计日志文件路径
# 记录数据变更、资源操作等
LOG_FILE_AUDIT=logs/audit.log

# SQL 日志文件路径
# 记录数据库查询（开发环境）
LOG_FILE_SQL=logs/sql.log

# Celery 任务日志文件路径
# 记录异步任务执行日志
LOG_FILE_CELERY=logs/celery.log

# WebSocket 日志文件路径
# 记录 WebSocket 连接和消息
LOG_FILE_WEBSOCKET=logs/websocket.log

# ============================================================
# 控制台日志配置
# ============================================================

# 是否启用控制台日志
# true: 日志输出到终端
# false: 不输出到终端
LOG_CONSOLE_ENABLED=true

# 控制台日志是否着色
# true: 不同级别用不同颜色（开发环境推荐）
# false: 无颜色
LOG_CONSOLE_COLORIZE=true

# ============================================================
# 日志格式配置
# ============================================================

# 日志输出格式
# %(asctime)s: 时间
# %(name)s: 日志记录器名称
# %(process)d: 进程 ID
# %(thread)d: 线程 ID
# %(levelname)s: 日志级别
# %(message)s: 日志消息
LOG_FORMAT=%(asctime)s - %(name)s - [%(process)d] - [%(thread)d] - %(levelname)s - %(message)s

# 日期格式
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# 是否使用 JSON 格式输出日志
# true: 输出 JSON 格式，便于日志收集系统解析
# false: 输出文本格式
LOG_JSON_ENABLED=false

# ============================================================
# 日志维度分离配置（按用户/活动/请求分离）
# ============================================================

# ============================================================
# 按用户分离日志配置
# ============================================================

# 是否启用按用户分离日志
# true: 为每个用户创建单独日志文件
# false: 所有用户共用日志文件
LOG_USER_SEPARATION_ENABLED=false

# 用户日志目录模板
# {user_id} 会被替换为实际用户 ID
LOG_USER_LOG_PATH=logs/users/{user_id}/

# 是否为每个用户创建单独文件
# true: logs/users/{user_id}/user.log
# false: 不创建单独文件
LOG_USER_FILE_ENABLED=false

# 最大用户日志文件数
# 超过此数后旧用户日志将被清理
LOG_USER_MAX_FILES=1000

# ============================================================
# 按活动分离日志配置
# ============================================================

# 是否启用按活动分离日志
# true: 为每个活动创建单独日志目录
# false: 所有活动共用日志文件
LOG_ACTIVITY_SEPARATION_ENABLED=true

# 活动日志目录模板
# {activity_id} 会被替换为实际活动 ID
LOG_ACTIVITY_LOG_PATH=logs/activities/{activity_id}/

# 是否为每个活动创建单独目录
# true: logs/activities/{activity_id}/
# false: 不创建单独目录
LOG_ACTIVITY_FILE_ENABLED=true

# 活动日志文件前缀
LOG_ACTIVITY_FILE_PREFIX=activity_{activity_id}

# 活动日志保留时间
# 超过此时间后自动删除
LOG_ACTIVITY_RETENTION=7days

# ============================================================
# 按请求分离日志配置（调试用）
# ============================================================

# 是否启用按请求分离日志
# true: 为每个请求创建单独日志文件
# false: 不分离（生产环境建议关闭）
LOG_REQUEST_SEPARATION_ENABLED=false

# 请求日志目录
LOG_REQUEST_LOG_PATH=logs/requests/

# 是否为每个请求创建单独文件
LOG_REQUEST_FILE_ENABLED=false

# 请求日志文件前缀模板
LOG_REQUEST_FILE_PREFIX=request_{request_id}_{timestamp}

# 单个请求日志文件最大大小（MB）
# 超过此大小会轮转
LOG_REQUEST_MAX_SIZE=1MB

# ============================================================
# 按 AI 任务类型分离日志配置
# ============================================================

# 是否启用按 AI 任务类型分离日志
# true: 按 chat/image/video/audio 等类型分离
# false: 不分离
LOG_AI_TASK_SEPARATION_ENABLED=true

# AI 任务日志目录模板
# {task_type} 会被替换为任务类型
LOG_AI_TASK_LOG_PATH=logs/ai/{task_type}/

# 是否启用文件分离
LOG_AI_TASK_FILE_ENABLED=true

# AI 任务日志文件前缀模板
LOG_AI_TASK_FILE_PREFIX={task_type}_{task_id}

# AI 任务类型列表（逗号分隔）
LOG_AI_TASK_TYPES=chat,image,video,audio,transcription,moderation

# ============================================================
# 日志通道详细配置
# ============================================================

# ============================================================
# 应用日志通道
# ============================================================

# 是否启用应用日志通道
LOG_CHANNEL_APP_ENABLED=true

# 应用日志级别
LOG_CHANNEL_LEVEL_APP=INFO

# 应用日志文件路径
LOG_CHANNEL_APP_FILE=logs/app.log

# ============================================================
# 错误日志通道
# ============================================================

# 是否启用错误日志通道
LOG_CHANNEL_ERROR_ENABLED=true

# 错误日志级别
# 建议: ERROR，只记录错误
LOG_CHANNEL_LEVEL_ERROR=ERROR

# 错误日志文件路径
LOG_CHANNEL_ERROR_FILE=logs/error.log

# 是否包含堆栈跟踪信息
# true: 记录完整的异常堆栈
# false: 只记录错误消息
LOG_CHANNEL_ERROR_INCLUDE_STACK_TRACE=true

# ============================================================
# 访问日志通道
# ============================================================

# 是否启用访问日志通道
LOG_CHANNEL_ACCESS_ENABLED=true

# 访问日志级别
LOG_CHANNEL_LEVEL_ACCESS=INFO

# 访问日志文件路径
LOG_CHANNEL_ACCESS_FILE=logs/access.log

# 访问日志格式
# json: JSON 格式（便于分析）
# text: 文本格式（便于阅读）
LOG_CHANNEL_ACCESS_FORMAT=json

# 是否包含请求头信息
# true: 记录请求头
# false: 不记录（减少日志大小）
LOG_CHANNEL_ACCESS_INCLUDE_HEADERS=false

# 是否包含请求体信息
# true: 记录请求体
# false: 不记录（保护敏感数据）
LOG_CHANNEL_ACCESS_INCLUDE_BODY=false

# 是否包含响应体信息
# true: 记录响应体
# false: 不记录（减少日志大小）
LOG_CHANNEL_ACCESS_INCLUDE_RESPONSE=false

# ============================================================
# 安全日志通道
# ============================================================

# 是否启用安全日志通道
LOG_CHANNEL_SECURITY_ENABLED=true

# 安全日志级别
# 建议: WARNING 及以上
LOG_CHANNEL_LEVEL_SECURITY=WARNING

# 安全日志文件路径
LOG_CHANNEL_SECURITY_FILE=logs/security.log

# 是否记录客户端 IP 地址
LOG_CHANNEL_SECURITY_INCLUDE_IP=true

# 是否记录 User-Agent
LOG_CHANNEL_SECURITY_INCLUDE_USER_AGENT=true

# ============================================================
# 审计日志通道
# ============================================================

# 是否启用审计日志通道
LOG_CHANNEL_AUDIT_ENABLED=true

# 审计日志级别
LOG_CHANNEL_LEVEL_AUDIT=INFO

# 审计日志文件路径
LOG_CHANNEL_AUDIT_FILE=logs/audit.log

# 是否记录读取操作
# true: 记录文件/数据读取
# false: 不记录
LOG_CHANNEL_AUDIT_INCLUDE_READ=true

# 是否记录删除操作
# true: 记录文件/数据删除
# false: 不记录
LOG_CHANNEL_AUDIT_INCLUDE_DELETE=true

# 是否记录下载操作
# true: 记录文件下载
# false: 不记录
LOG_CHANNEL_AUDIT_INCLUDE_DOWNLOAD=true

# ============================================================
# SQL 日志通道
# ============================================================

# 是否启用 SQL 日志通道
# 建议: 仅开发环境启用
LOG_CHANNEL_SQL_ENABLED=false

# SQL 日志级别
LOG_CHANNEL_LEVEL_SQL=DEBUG

# SQL 日志文件路径
LOG_CHANNEL_SQL_FILE=logs/sql.log

# 是否记录绑定参数值
# true: 记录完整的 SQL 参数
# false: 只记录 SQL 模板
LOG_CHANNEL_SQL_INCLUDE_BIND_PARAMS=true

# 是否记录查询结果
# true: 记录查询返回的数据
# false: 不记录
LOG_CHANNEL_SQL_INCLUDE_RESULT=false

# 最小记录时长（毫秒）
# 仅记录执行时间超过此值的查询
# 0: 记录所有查询
LOG_CHANNEL_SQL_MIN_DURATION=0

# ============================================================
# Celery 日志通道
# ============================================================

# 是否启用 Celery 日志通道
LOG_CHANNEL_CELERY_ENABLED=true

# Celery 日志级别
LOG_CHANNEL_LEVEL_CELERY=INFO

# Celery 日志文件路径
LOG_CHANNEL_CELERY_FILE=logs/celery.log

# ============================================================
# WebSocket 日志通道
# ============================================================

# 是否启用 WebSocket 日志通道
LOG_CHANNEL_WEBSOCKET_ENABLED=true

# WebSocket 日志级别
LOG_CHANNEL_LEVEL_WEBSOCKET=INFO

# WebSocket 日志文件路径
LOG_CHANNEL_WEBSOCKET_FILE=logs/websocket.log

# ============================================================
# 日志轮转配置
# ============================================================

# 全局日志轮转触发条件
# midnight: 每天午夜
# S: 每秒
# M: 每分钟
# H: 每小时
# D: 每天
LOG_ROTATION_WHEN=midnight

# 轮转间隔（配合 WHEN 使用）
# 配合 midnight 使用时表示每 N 天
LOG_ROTATION_INTERVAL=1

# 单个日志文件最大大小
# 超过此大小立即轮转
# 104857600 = 100MB
LOG_MAX_BYTES=104857600

# 保留的备份文件数量
# 超过此数量后旧文件被删除
LOG_BACKUP_COUNT=30

# ============================================================
# 应用日志轮转配置
# ============================================================

# 应用日志轮转触发条件
LOG_ROTATION_APP_WHEN=midnight

# 应用日志文件最大大小
LOG_ROTATION_APP_MAX_BYTES=104857600

# 应用日志备份保留数量
LOG_ROTATION_APP_BACKUP_COUNT=30

# ============================================================
# 访问日志轮转配置
# ============================================================

# 访问日志轮转触发条件
LOG_ROTATION_ACCESS_WHEN=midnight

# 访问日志文件最大大小（访问量大，设置更大）
# 209715200 = 200MB
LOG_ROTATION_ACCESS_MAX_BYTES=209715200

# 访问日志备份保留数量
LOG_ROTATION_ACCESS_BACKUP_COUNT=30

# ============================================================
# 错误日志轮转配置
# ============================================================

# 错误日志轮转触发条件
LOG_ROTATION_ERROR_WHEN=midnight

# 错误日志文件最大大小
# 52428800 = 50MB
LOG_ROTATION_ERROR_MAX_BYTES=52428800

# 错误日志备份保留数量（保留更长时间）
LOG_ROTATION_ERROR_BACKUP_COUNT=60

# ============================================================
# SQL 日志轮转配置
# ============================================================

# SQL 日志轮转触发条件
LOG_ROTATION_SQL_WHEN=midnight

# SQL 日志文件最大大小
LOG_ROTATION_SQL_MAX_BYTES=104857600

# SQL 日志备份保留数量
LOG_ROTATION_SQL_BACKUP_COUNT=7

# ============================================================
# 活动日志轮转配置
# ============================================================

# 活动日志轮转触发条件
LOG_ROTATION_ACTIVITY_WHEN=midnight

# 活动日志文件最大大小
LOG_ROTATION_ACTIVITY_MAX_BYTES=52428800

# 活动日志备份保留数量
LOG_ROTATION_ACTIVITY_BACKUP_COUNT=7

# ============================================================
# 异步日志配置
# ============================================================

# 是否启用异步日志
# true: 日志写入队列，异步写入文件
# false: 同步写入（简单可靠）
# 高并发场景建议开启，提升性能
LOG_ASYNC_ENABLED=false

# 异步队列大小
# 队列满时新日志会被丢弃或阻塞
LOG_ASYNC_QUEUE_SIZE=10000

# 队列满时是否阻塞等待
# true: 等待队列有空位
# false: 丢弃超出的日志
LOG_ASYNC_BLOCK_ON_FULL_QUEUE=true

# 队列满时丢弃等待时间（秒）
# 超过此时间后丢弃日志
LOG_ASYNC_DROP_TIMEOUT=5

# ============================================================
# 日志缓冲配置
# ============================================================

# 是否启用日志缓冲
# true: 先写入缓冲区，定期刷新
# false: 立即写入
LOG_BUFFER_ENABLED=false

# 缓冲区大小
# 达到此数量后刷新到文件
LOG_BUFFER_SIZE=1000

# 缓冲区刷新间隔（秒）
LOG_BUFFER_FLUSH_INTERVAL=5

# ============================================================
# 日志过滤配置
# ============================================================

# 是否过滤敏感数据
# true: 自动替换敏感信息
# false: 不过滤
LOG_FILTER_SENSITIVE_DATA=true

# 敏感数据匹配模式（逗号分隔）
# 日志中包含这些关键词的内容会被替换
LOG_FILTER_PATTERNS=password,token,secret,key,authorization

# 敏感数据替换字符
LOG_FILTER_REPLACEMENT=***

# ============================================================
# 日志采样配置
# ============================================================

# 是否启用日志采样
# true: 按比例采样，减少日志量
# false: 记录所有日志
# 高流量场景建议开启
LOG_SAMPLING_ENABLED=false

# 采样率（0-1）
# 0.1 = 10% 的日志被记录
LOG_SAMPLING_RATE=0.1

# 采样策略
# random: 随机采样
# rate_limit: 按速率采样
# priority: 按优先级采样
LOG_SAMPLING_STRATEGY=random

# ============================================================
# 日志聚合配置（多实例汇总）
# ============================================================

# 是否启用日志聚合
# true: 发送到日志收集服务（如 ELK）
# false: 本地存储
LOG_AGGREGATION_ENABLED=false

# 日志聚合服务地址
LOG_AGGREGATION_HOST=localhost

# 日志聚合服务端口
LOG_AGGREGATION_PORT=5044

# 传输协议
# tcp: 可靠传输（推荐）
# udp: 高效但不保证到达
# http: HTTP 协议
LOG_AGGREGATION_PROTOCOL=tcp

# ============================================================
# 监控与指标配置
# ============================================================

# 是否启用监控指标
# true: 启用，收集运行时指标
# false: 禁用
METRICS_ENABLED=true

# 监控指标端口
# 独立于主应用端口
METRICS_PORT=9090

# Prometheus 指标端点路径
METRICS_PATH=/metrics

# 健康检查端点路径
HEALTH_CHECK_PATH=/system/health

# ============================================================
# 健康检查配置
# ============================================================

# 是否返回详细信息
# true: 返回各组件详细状态
# false: 只返回是否健康
HEALTH_CHECK_DETAILED=true

# 是否检查私网依赖
# true: 检查内网服务（数据库、Redis）
# false: 跳过私网依赖
HEALTH_CHECK_ALLOW_PRIVATE=true

# 是否检查数据库连接
HEALTH_CHECK_DB=true

# 是否检查 Redis 连接
HEALTH_CHECK_REDIS=true

# 是否检查 S3 连接
HEALTH_CHECK_S3=true

# 是否检查 LLM 服务
HEALTH_CHECK_LLM=true

# 是否检查外部服务
HEALTH_CHECK_EXTERNAL=true

# ============================================================
# 指标收集配置
# ============================================================

# 指标收集器类型
# prometheus: Prometheus（推荐）
# statsd: StatsD
# datadog: Datadog
METRICS_COLLECTOR=prometheus

# 指标导出格式
# prometheus: Prometheus 格式
# json: JSON 格式
# influxdb: InfluxDB 格式
METRICS_EXPORT_FORMAT=prometheus

# Prometheus 多进程目录
# 用于多 Worker 进程模式
PROMETHEUS_MULTIPROC_DIR=./metrics

# Prometheus 端口
PROMETHEUS_PORT=9091

# ============================================================
# StatsD 配置
# ============================================================

# StatsD 主机地址
STATSD_HOST=localhost

# StatsD 端口
STATSD_PORT=8125

# 指标前缀（用于区分不同服务）
STATSD_PREFIX=trai

# ============================================================
# Grafana 配置
# ============================================================

# 是否启用 Grafana 集成
# true: 启用，可直接在 Grafana 查看
# false: 禁用
GRAFANA_ENABLED=false

# Grafana 服务地址
GRAFANA_URL=http://localhost:3000

# Grafana API Key
# 用于认证和授权
GRAFANA_API_KEY=

# Grafana Dashboard UID
# 用于指定展示哪个 Dashboard
GRAFANA_DASHBOARD_UID=trai-backend

# ============================================================
# 性能监控配置
# ============================================================

# 是否启用性能监控
# true: 记录请求响应时间等
# false: 禁用
PERFORMANCE_MONITORING_ENABLED=true

# 性能采样率（0-1）
# 1.0 = 记录所有请求
# 降低可减少性能开销
PERFORMANCE_MONITORING_SAMPLE_RATE=1.0

# 是否在性能数据中包含请求头
# true: 包含（便于调试）
# false: 不包含（减少数据量）
PERFORMANCE_MONITORING_INCLUDE_HEADERS=false

# ============================================================
# 异常追踪配置
# ============================================================

# 是否启用异常追踪
# true: 启用，收集未处理异常
# false: 禁用
ERROR_TRACKING_ENABLED=true

# 异常追踪服务提供商
# sentry: Sentry（推荐）
# bugsnag: Bugsnag
# custom: 自建服务
ERROR_TRACKING_PROVIDER=sentry

# 异常采样率（0-1）
# 1.0 = 记录所有异常
ERROR_TRACKING_SAMPLE_RATE=1.0

# ============================================================
# Sentry 配置
# ============================================================

# Sentry DSN（Data Source Name）
# 用于连接 Sentry 服务
# 格式: https://xxx@sentry.io/xxx
SENTRY_DSN=

# Sentry 环境名称
# 示例: development, staging, production
SENTRY_ENVIRONMENT=development

# 链路追踪采样率（0-1）
# 0.1 = 10% 的请求会被追踪
SENTRY_TRACES_SAMPLE_RATE=0.1

# 性能分析采样率（0-1）
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================
# APM 配置
# ============================================================

# 是否启用 APM（应用性能监控）
# true: 启用，请求链路追踪
# false: 禁用
APM_ENABLED=false

# APM 服务名称
APM_SERVICE_NAME=trai-backend

# APM 服务地址
# 例如: Elastic APM Server
APM_SERVER_URL=http://localhost:8200

# APM 认证 Token
APM_SECRET_TOKEN=

# ============================================================
# OpenTelemetry 链路追踪配置
# ============================================================

# 是否启用 OpenTelemetry
# true: 启用分布式追踪
# false: 禁用
OTEL_ENABLED=false

# 服务名称
OTEL_SERVICE_NAME=trai-backend

# OTLP 导出器地址
# gRPC: localhost:4317
# HTTP: localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# 链路采样器类型
# parentbased_traceidratio: 基于父级追踪的采样
# always_on: 全部记录
# always_off: 全部跳过
# ratio: 按比例采样
OTEL_TRACES_SAMPLER=parentbased_traceidratio

# 采样率参数（0-1）
OTEL_TRACES_SAMPLER_ARG=0.1

# ============================================================
# OpenTelemetry 详细配置
# ============================================================

# OTLP 协议
# grpc: gRPC 协议（推荐）
# http/protobuf: HTTP 协议
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# 链路追踪导出端点
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4317

# 指标导出端点
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4317

# 日志导出端点
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318

# 自定义 Header（认证用）
# 格式: key1=value1,key2=value2
OTEL_EXPORTER_OTLP_HEADERS=

# ============================================================
# 链路追踪详细配置
# ============================================================

# 是否启用链路追踪
OTEL_TRACES_ENABLED=true

# Debug 模式下是否采样
OTEL_TRACES_SAMPLE_ON_DEBUG=false

# 排除追踪的路径（逗号分隔）
# 这些路径不会被追踪
OTEL_TRACES_EXCLUDED_PATHS=/health,/metrics,/docs,/openapi.json

# Span 属性数量限制
OTEL_SPAN_ATTRIBUTE_COUNT_LIMIT=128

# Span 事件数量限制
OTEL_EVENT_ATTRIBUTE_COUNT_LIMIT=128

# Span 链接数量限制
OTEL_LINK_ATTRIBUTE_COUNT_LIMIT=128

# ============================================================
# OpenTelemetry 指标配置
# ============================================================

# 是否启用指标收集
OTEL_METRICS_ENABLED=true

# 指标导出间隔（毫秒）
# 60000 = 1 分钟
OTEL_METRICS_EXPORT_INTERVAL=60000

# ============================================================
# OpenTelemetry 日志配置
# ============================================================

# 是否启用日志集成
OTEL_LOGS_ENABLED=false

# 日志级别
OTEL_LOG_LEVEL=INFO

# ============================================================
# OpenTelemetry Baggage 配置
# ============================================================

# 是否启用 Baggage
# Baggage 用于在链路中传递上下文信息
OTEL_BAGGAGE_ENABLED=true

# Baggage Key 前缀
OTEL_BAGGAGE_PREFIX=trai/

# ============================================================
# 缓存配置
# ============================================================

# 是否启用缓存
# true: 启用，减少重复计算
# false: 禁用，每次都从源头获取
CACHE_ENABLED=true

# 缓存存储后端
# redis: Redis 缓存（推荐）
# memory: 内存缓存（仅单进程）
# memcached: Memcached
CACHE_TYPE=redis

# 默认缓存过期时间（秒）
# 300 = 5 分钟
CACHE_DEFAULT_TIMEOUT=300

# 缓存 Key 前缀
# 用于区分不同应用的缓存
CACHE_KEY_PREFIX=trai:cache:

# ============================================================
# 缓存策略配置
# ============================================================

# 默认缓存策略
# no_cache: 不缓存
# cache_per_user: 按用户缓存
# cache_per_role: 按角色缓存
CACHE_STRATEGY_DEFAULT=no_cache

# 是否启用缓存版本控制
# true: 缓存数据有版本号
# false: 无版本控制
CACHE_VERSION_ENABLED=false

# 缓存版本号
# 修改后旧缓存会自动失效
CACHE_VERSION_KEY=1

# ============================================================
# 缓存预热配置
# ============================================================

# 是否启用缓存预热
# true: 启动时自动加载热点数据
# false: 按需加载
CACHE_WARMUP_ENABLED=false

# 预热路径列表（逗号分隔）
# 启动时访问这些路径加载数据
CACHE_WARMUP_PATHS=/api/v1/ai/models,/api/v1/system/config

# ============================================================
# 缓存失效配置
# ============================================================

# 更新时是否自动失效相关缓存
# true: 数据更新时清除缓存
# false: 等待缓存自然过期
CACHE_INVALIDATE_ON_UPDATE=true

# 缓存失效匹配模式
CACHE_INVALIDATE_PATTERNS=trai:cache:*:*:*

# ============================================================
# 文件上传配置
# ============================================================

# 是否启用文件上传功能
# true: 允许用户上传文件
# false: 禁止所有文件上传
UPLOAD_ENABLED=true

# 临时文件存储目录（相对于 backend 根目录）
# 上传过程中的临时文件存放位置
# 建议: 使用独立磁盘或 SSD
UPLOAD_TEMP_PATH=./uploads/temp

# 永久文件存储目录（相对于 backend 根目录）
# 上传完成的文件最终存放位置
UPLOAD_PERMANENT_PATH=./uploads/files

# ============================================================
# 文件类型分类配置
# ============================================================
# 文件类型分类，影响存储路径和处理方式

# 图片类型文件扩展名（逗号分隔）
UPLOAD_TYPE_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp,bmp,svg,ico,tiff,raw,psd,heic,avif

# 视频类型文件扩展名
UPLOAD_TYPE_VIDEO_EXTENSIONS=mp4,avi,mov,wmv,flv,mkv,mpeg,mpg,m4v,webm,3gp,ogv,rmvb

# 音频类型文件扩展名
UPLOAD_TYPE_AUDIO_EXTENSIONS=mp3,wav,flac,aac,ogg,m4a,wma,opus,ape,alac,ac3

# 文档类型文件扩展名
UPLOAD_TYPE_DOCUMENT_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,rtf,odt,ods,odp,csv,tsv

# 压缩包类型文件扩展名
UPLOAD_TYPE_ARCHIVE_EXTENSIONS=zip,rar,7z,tar,gz,bz2,xz,tgz,tar.gz,tar.bz2

# 代码类型文件扩展名
UPLOAD_TYPE_CODE_EXTENSIONS=py,js,ts,java,c,cpp,h,go,rs,rb,php,html,css,json,xml,yaml,yml,md,sql,sh,bat,ps1

# 字体类型文件扩展名
UPLOAD_TYPE_FONT_EXTENSIONS=ttf,otf,woff,woff2,eot

# 3D 模型类型文件扩展名
UPLOAD_TYPE_3D_EXTENSIONS=obj,fbx,stl,3ds,dae,gltf,glb,blend

# ============================================================
# 文件大小限制配置（按类型分别设置）
# ============================================================

# 全局文件大小限制（MB）
# 作为兜底限制，任何文件都不能超过此大小
UPLOAD_MAX_SIZE=500

# ----------------------------------------
# 图片文件大小限制
# ----------------------------------------

# 图片文件最大大小（MB）
# 建议: 10-50MB（取决于分辨率需求）
UPLOAD_IMAGE_MAX_SIZE=20

# 图片文件最小大小（KB）
# 用于检测损坏或空文件
UPLOAD_IMAGE_MIN_SIZE=1

# ----------------------------------------
# 视频文件大小限制
# ----------------------------------------

# 视频文件最大大小（MB）
# 建议: 根据业务需求调整，高清视频可能需要更大
UPLOAD_VIDEO_MAX_SIZE=500

# 视频文件最小大小（KB）
UPLOAD_VIDEO_MIN_SIZE=100

# 视频最大时长限制（秒）
# 用于上传后校验视频长度
UPLOAD_VIDEO_MAX_DURATION=7200

# ----------------------------------------
# 音频文件大小限制
# ----------------------------------------

# 音频文件最大大小（MB）
UPLOAD_AUDIO_MAX_SIZE=100

# 音频文件最小大小（KB）
UPLOAD_AUDIO_MIN_SIZE=10

# 音频最大时长限制（秒）
UPLOAD_AUDIO_MAX_DURATION=3600

# ----------------------------------------
# 文档文件大小限制
# ----------------------------------------

# 文档文件最大大小（MB）
# PDF、Word、Excel 等
UPLOAD_DOCUMENT_MAX_SIZE=50

# 文档文件最小大小（KB）
UPLOAD_DOCUMENT_MIN_SIZE=1

# ----------------------------------------
# 压缩包文件大小限制
# ----------------------------------------

# 压缩包最大大小（MB）
UPLOAD_ARCHIVE_MAX_SIZE=200

# ----------------------------------------
# 代码文件大小限制
# ----------------------------------------

# 代码文件最大大小（KB）
# 代码文件通常较小
UPLOAD_CODE_MAX_SIZE=5000

# ----------------------------------------
# 字体文件大小限制
# ----------------------------------------

# 字体文件最大大小（MB）
UPLOAD_FONT_MAX_SIZE=10

# ----------------------------------------
# 3D 模型文件大小限制
# ----------------------------------------

# 3D 模型文件最大大小（MB）
UPLOAD_3D_MAX_SIZE=100

# ============================================================
# 允许的文件扩展名配置
# ============================================================

# 允许上传的扩展名（逗号分隔）
# 空: 允许所有扩展名
# 非空: 仅允许列表中的扩展名（推荐）
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,bmp,svg,mp4,avi,mov,wmv,flv,mp3,wav,flac,aac,ogg,pdf,doc,docx,xls,xlsx,ppt,pptx,txt,csv,zip,rar,7z

# 禁止上传的扩展名（逗号分隔）
# 优先级高于 ALLOWED_EXTENSIONS
# 出于安全考虑，禁止可执行文件和脚本
UPLOAD_FORBIDDEN_EXTENSIONS=exe,sh,py,js,jar,dll,so,bat,cmd,ps1,vbs,scr,pif,mde,msi,com,app

# ============================================================
# 文件存储路径配置（按类型分离）
# ============================================================

# 是否按文件类型分离存储路径
# true: 不同类型文件存储在不同目录
# false: 统一存储
UPLOAD_PATH_BY_TYPE=true

# 图片存储目录（相对于 UPLOAD_PERMANENT_PATH）
UPLOAD_PATH_IMAGE=images/

# 视频存储目录
UPLOAD_PATH_VIDEO=videos/

# 音频存储目录
UPLOAD_PATH_AUDIO=audios/

# 文档存储目录
UPLOAD_PATH_DOCUMENT=documents/

# 压缩包存储目录
UPLOAD_PATH_ARCHIVE=archives/

# 代码存储目录
UPLOAD_PATH_CODE=codes/

# 字体存储目录
UPLOAD_PATH_FONT=fonts/

# 3D 模型存储目录
UPLOAD_PATH_3D=models/

# 未知类型存储目录
UPLOAD_PATH_OTHER=others/

# ============================================================
# 文件命名配置
# ============================================================

# 上传文件重命名策略
# uuid: 使用 UUID 命名（推荐，唯一性强）
# timestamp: 使用时间戳命名
# original: 保留原始文件名
# hash: 使用文件内容哈希命名
UPLOAD_NAMING_STRATEGY=uuid

# 保留原始文件扩展名
# true: 保留（推荐，更易识别文件类型）
# false: 转换为统一格式
UPLOAD_KEEP_EXTENSION=true

# 原始文件名处理策略
# ignore: 完全忽略原始文件名
# sanitize: 清理特殊字符后保留
# prefix: UUID 前缀 + 原始文件名
UPLOAD_ORIGINAL_NAME=ignore

# 文件名最大长度（字符）
# 超出部分将被截断
UPLOAD_FILENAME_MAX_LENGTH=255

# ============================================================
# 分片上传配置
# ============================================================

# 是否启用分片上传
# true: 大文件自动分片上传，支持断点续传
# false: 普通上传，不支持断点续传
UPLOAD_CHUNK_ENABLED=true

# 分片大小（MB）
# 每个分片的大小，建议 1-10MB
# 越小: 分片越多，上传请求更多
# 越大: 分片越少，但失败重传代价大
UPLOAD_CHUNK_SIZE=5

# 分片超时时间（秒）
# 单个分片上传超时时间
UPLOAD_CHUNK_TIMEOUT=300

# 分片最大重试次数
# 单个分片上传失败后的重试次数
UPLOAD_CHUNK_MAX_RETRIES=3

# 分片重试间隔（秒）
# 失败后等待时间逐步增加
UPLOAD_CHUNK_RETRY_DELAY=5

# 最大分片数量
# 限制单个文件的最大分片数
# 防止恶意构造大量分片
UPLOAD_CHUNK_MAX_COUNT=500

# 最小分片大小（KB）
# 小于此大小的文件不分片
UPLOAD_CHUNK_MIN_FILE_SIZE=10485760

# 分片合并超时时间（秒）
# 所有分片上传后，合并操作的超时时间
UPLOAD_CHUNK_MERGE_TIMEOUT=600

# 分片临时目录
# 分片文件上传后的临时存放位置
UPLOAD_CHUNK_TEMP_PATH=./uploads/chunks/

# 分片合并后是否删除分片
# true: 删除，节省磁盘空间
# false: 保留，便于调试
UPLOAD_CHUNK_DELETE_AFTER_MERGE=true

# 分片有效期（秒）
# 分片上传后超过此时间未完成合并将被清理
UPLOAD_CHUNK_EXPIRE_TIME=86400

# ============================================================
# 并行上传配置
# ============================================================

# 是否启用并行上传
# true: 同时上传多个分片
# false: 顺序上传
UPLOAD_PARALLEL_ENABLED=true

# 并行上传线程数
# 同时上传的分片数量
# 建议: 2-8，根据带宽调整
UPLOAD_PARALLEL_THREADS=3

# 并行上传最大并发数
# 全局最大并发上传数
UPLOAD_PARALLEL_MAX_CONCURRENT=10

# 每个分片的并行请求数
# 单个分片使用多个连接上传
# 用于提高单个大文件的传输速度
UPLOAD_PARALLEL_CHUNK_CONNECTIONS=1

# 是否启用流量控制
# true: 根据服务器负载动态调整并发
# false: 固定并发数
UPLOAD_PARALLEL_FLOW_CONTROL=true

# 流量控制最小并发数
UPLOAD_PARALLEL_MIN_CONCURRENT=1

# 流量控制最大并发数
UPLOAD_PARALLEL_MAX_CONCURRENT_LIMIT=20

# ============================================================
# 文件验证配置
# ============================================================

# 是否验证文件大小
# true: 上传前校验文件大小
# false: 不校验
UPLOAD_VALIDATE_SIZE=true

# 是否验证文件扩展名
# true: 校验扩展名是否在允许列表
# false: 不校验
UPLOAD_VALIDATE_EXTENSION=true

# 是否验证文件 MIME 类型
# true: 通过文件内容检测类型
# false: 仅依赖扩展名
UPLOAD_VALIDATE_MIME=true

# MIME 类型白名单
# 仅允许的白名单 MIME 类型
UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,image/gif,image/webp,video/mp4,audio/mpeg,audio/wav,application/pdf

# 是否验证文件内容（Magic Number）
# true: 检测文件头部签名
# false: 不检测
UPLOAD_VALIDATE_MAGIC=true

# 文件内容签名白名单（十六进制）
# 用于验证文件真实类型
UPLOAD_MAGIC_NUMBERS=ffd8ff:image/jpeg,89504e47:image/png,47494638:image/gif,25504446:application/pdf

# 是否检测文件损坏
# true: 验证文件完整性
# false: 不验证
UPLOAD_VALIDATE_INTEGRITY=true

# 完整性校验方式
# md5: MD5 校验（快速）
# sha256: SHA256 校验（更安全）
# none: 不校验
UPLOAD_INTEGRITY_CHECK=sha256

# ============================================================
# 图像处理配置
# ============================================================

# 是否启用图像自动处理
# true: 上传时自动调整大小、压缩
# false: 保持原样
UPLOAD_IMAGE_RESIZE_ENABLED=true

# 图像处理质量模式
# high: 高质量，文件较大
# balanced: 平衡模式（推荐）
# low: 低质量，文件小
UPLOAD_IMAGE_QUALITY_MODE=balanced

# 图像压缩质量（1-100）
# 数值越小文件越小，但质量下降
UPLOAD_IMAGE_QUALITY=85

# 图像最大宽度（像素）
# 超过此宽度将等比缩放
UPLOAD_IMAGE_MAX_WIDTH=4096

# 图像最大高度（像素）
# 超过此高度将等比缩放
UPLOAD_IMAGE_MAX_HEIGHT=4096

# 图像最小宽度（像素）
# 低于此宽度可能被拒绝
UPLOAD_IMAGE_MIN_WIDTH=10

# 图像最小高度（像素）
UPLOAD_IMAGE_MIN_HEIGHT=10

# 是否保持宽高比
# true: 等比缩放
# false: 强制调整为指定尺寸
UPLOAD_IMAGE_KEEP_ASPECT=true

# 图像转换格式
# original: 保持原格式
# webp: 转换为 WebP（推荐，体积小）
# jpeg: 转换为 JPEG
# png: 转换为 PNG
UPLOAD_IMAGE_FORMAT=original

# 是否生成缩略图
# true: 为图片生成缩略图
# false: 不生成
UPLOAD_IMAGE_THUMBNAIL_ENABLED=true

# 缩略图宽度
UPLOAD_IMAGE_THUMBNAIL_WIDTH=200

# 缩略图高度
UPLOAD_IMAGE_THUMBNAIL_HEIGHT=200

# 缩略图质量（1-100）
UPLOAD_IMAGE_THUMBNAIL_QUALITY=70

# 缩略图命名后缀
UPLOAD_IMAGE_THUMBNAIL_SUFFIX=_thumb

# ============================================================
# 视频处理配置
# ============================================================

# 是否生成视频缩略图
# true: 自动截取视频首帧作为缩略图
# false: 不生成
UPLOAD_VIDEO_THUMBNAIL_ENABLED=true

# 缩略图截取时间点（秒）
# 从视频开始多少秒处截取
UPLOAD_VIDEO_THUMBNAIL_TIME=1

# 视频缩略图宽度
UPLOAD_VIDEO_THUMBNAIL_WIDTH=320

# 视频缩略图高度
UPLOAD_VIDEO_THUMBNAIL_HEIGHT=180

# 是否生成视频水印
# true: 添加水印
# false: 不添加
UPLOAD_VIDEO_WATERMARK_ENABLED=false

# 水印位置
# top_left: 左上
# top_right: 右上
# bottom_left: 左下
# bottom_right: 右下
# center: 居中
UPLOAD_VIDEO_WATERMARK_POSITION=bottom_right

# 水印图片路径
UPLOAD_VIDEO_WATERMARK_IMAGE=./static/watermark.png

# 水印透明度（0-1）
UPLOAD_VIDEO_WATERMARK_OPACITY=0.3

# 是否转码为统一格式
# true: 转换为 H.264/MP4
# false: 保持原格式
UPLOAD_VIDEO_TRANSCODING=false

# 转码目标格式
UPLOAD_VIDEO_TRANSCODE_FORMAT=mp4

# 是否提取视频封面
# true: 提取视频封面图
# false: 不提取
UPLOAD_VIDEO_COVER_EXTRACT=true

# 封面提取时间点（秒）
UPLOAD_VIDEO_COVER_TIME=5

# ============================================================
# 音频处理配置
# ============================================================

# 是否转码为统一格式
# true: 转换为 MP3
# false: 保持原格式
UPLOAD_AUDIO_TRANSCODING=false

# 转码目标格式
UPLOAD_AUDIO_TRANSCODE_FORMAT=mp3

# 转码目标比特率（kbps）
UPLOAD_AUDIO_TRANSCODE_BITRATE=128

# 是否提取音频封面
# true: 从音频文件中提取封面
# false: 不提取
UPLOAD_AUDIO_COVER_EXTRACT=true

# 是否提取音频元数据
# true: 提取歌曲名、歌手、专辑等信息
# false: 不提取
UPLOAD_AUDIO_METADATA_EXTRACT=true

# ============================================================
# 文档处理配置
# ============================================================

# 是否生成文档预览图
# true: 为 PDF、Word 等生成预览图
# false: 不生成
UPLOAD_DOCUMENT_PREVIEW_ENABLED=true

# 预览图宽度
UPLOAD_DOCUMENT_PREVIEW_WIDTH=800

# 预览图格式
# png: PNG 格式
# jpeg: JPEG 格式
UPLOAD_DOCUMENT_PREVIEW_FORMAT=png

# PDF 预览分辨率（DPI）
# 越高越清晰，文件越大
UPLOAD_DOCUMENT_PDF_DPI=150

# 预览页数限制
# 最多生成多少页预览
UPLOAD_DOCUMENT_PREVIEW_MAX_PAGES=10

# 是否提取文档文本
# true: 提取可搜索文本
# false: 不提取
UPLOAD_DOCUMENT_TEXT_EXTRACT=true

# ============================================================
# 安全与清理配置
# ============================================================

# 是否自动清理孤立文件
# true: 定期清理无引用的文件
# false: 不清理
UPLOAD_CLEANUP_ENABLED=true

# 孤立文件清理间隔（小时）
UPLOAD_CLEANUP_INTERVAL=24

# 文件保留天数
# 上传后超过此天数的孤立文件将被删除
UPLOAD_RETENTION_DAYS=30

# 临时文件清理间隔（小时）
UPLOAD_TEMP_CLEANUP_INTERVAL=1

# 临时文件保留时间（小时）
UPLOAD_TEMP_RETENTION_HOURS=24

# 分片过期清理间隔（小时）
UPLOAD_CHUNK_CLEANUP_INTERVAL=6

# ============================================================
# WebSocket 配置
# ============================================================

# 是否启用 WebSocket
# true: 支持实时双向通信
# false: 仅 HTTP
WEBSOCKET_ENABLED=true

# WebSocket 端点路径
WEBSOCKET_PATH=/ws

# 心跳间隔（秒）
# 定期发送 ping 保持连接活跃
WEBSOCKET_PING_INTERVAL=30

# 心跳超时（秒）
# 超过此时间未收到 pong 判定为断开
WEBSOCKET_PING_TIMEOUT=10

# 最大消息大小（字节）
# 10485760 = 10MB
WEBSOCKET_MAX_MESSAGE_SIZE=10485760

# WebSocket 房间前缀
WEBSOCKET_ROOM_PREFIX=room:

# WebSocket 用户前缀
WEBSOCKET_USER_PREFIX=user:

# 每个用户最大房间数
WEBSOCKET_MAX_ROOMS_PER_USER=10

# ============================================================
# 邮件配置
# ============================================================

# 是否启用邮件功能
# true: 可以发送邮件
# false: 禁用邮件
EMAIL_ENABLED=false

# ============================================================
# SMTP 标准邮件配置
# ============================================================

# SMTP 服务器地址
EMAIL_SMTP_HOST=smtp.example.com

# SMTP 端口
# 25: 标准（常被防火墙阻止）
# 465: SMTP over SSL
# 587: STARTTLS（推荐）
EMAIL_SMTP_PORT=587

# SMTP 用户名
EMAIL_SMTP_USER=noreply@example.com

# SMTP 密码
# 【重要】生产环境必须使用强密码
EMAIL_SMTP_PASSWORD=

# 是否使用 STARTTLS
# true: 使用 587 端口
# false: 使用 465 端口
EMAIL_SMTP_USE_TLS=true

# 是否使用 SSL
# true: 使用 465 端口
# false: 不使用
EMAIL_SMTP_USE_SSL=false

# SMTP 连接超时（秒）
EMAIL_SMTP_TIMEOUT=30

# 发件人显示名称
EMAIL_SMTP_FROM_NAME=TRAI System

# 发件人邮箱地址
EMAIL_SMTP_FROM_ADDRESS=noreply@example.com

# ============================================================
# 企业微信邮件配置
# ============================================================

# 是否启用企业微信邮件
EMAIL_WECOM_ENABLED=false

# 企业 ID
EMAIL_WECOM_CORP_ID=ww1234567890abcdef

# 应用 Secret
EMAIL_WECOM_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 发件人名称
EMAIL_WECOM_FROM_NAME=TRAI System

# ============================================================
# 钉钉邮件配置
# ============================================================

# 是否启用钉钉邮件
EMAIL_DINGTALK_ENABLED=false

# Access Key ID
EMAIL_DINGTALK_ACCESS_KEY=xxxxxxxxxxxxxxxxXXXXXXXX

# Access Key Secret
EMAIL_DINGTALK_ACCESS_SECRET=xxxxxxxxXXXXXXXXXXXXXXXX

# 发件人名称
EMAIL_DINGTALK_FROM_NAME=TRAI System

# ============================================================
# 飞书邮件配置
# ============================================================

# 是否启用飞书邮件
EMAIL_FEISHU_ENABLED=false

# App ID
EMAIL_FEISHU_APP_ID=cli_xxxxxxxxxxxxxx

# App Secret
EMAIL_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 发件人名称
EMAIL_FEISHU_FROM_NAME=TRAI System

# ============================================================
# SendGrid 邮件配置
# ============================================================

# 是否启用 SendGrid
EMAIL_SENDGRID_ENABLED=false

# SendGrid API Key
EMAIL_SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 发件人名称
EMAIL_SENDGRID_FROM_NAME=TRAI System

# 发件人地址
EMAIL_SENDGRID_FROM_ADDRESS=noreply@example.com

# ============================================================
# 阿里云邮件推送配置
# ============================================================

# 是否启用阿里云邮件推送
EMAIL_ALIYUN_ENABLED=false

# Access Key ID
EMAIL_ALIYUN_ACCESS_KEY=xxxxxxxxxxxxxxxxXXXXXXXX

# Access Key Secret
EMAIL_ALIYUN_ACCESS_SECRET=xxxxxxxxXXXXXXXXXXXXXXXX

# 发件账号
EMAIL_ALIYUN_ACCOUNT_NAME=noreply@example.com

# 发件人名称
EMAIL_ALIYUN_FROM_NAME=TRAI System

# ============================================================
# 邮件通用配置
# ============================================================

# 默认邮件发送渠道
# 用于未指定渠道时
EMAIL_DEFAULT_PROVIDER=smtp

# 邮件发送超时（秒）
EMAIL_TIMEOUT=30

# 单封邮件最大收件人数量
# 超过此数量需要分批发送
EMAIL_MAX_RECIPIENTS=50

# 每日发送上限
# 用于防止滥用
EMAIL_DAILY_LIMIT=1000

# 是否启用 HTML 模板
# true: 支持 HTML 格式邮件
# false: 仅支持纯文本
EMAIL_HTML_ENABLED=true

# ============================================================
# 邮件场景配置
# ============================================================

# 欢迎邮件发送渠道（逗号分隔）
# 格式: 渠道1,渠道2
EMAIL_SCENE_WELCOME_PROVIDERS=smtp

# 密码重置邮件发送渠道
EMAIL_SCENE_RESET_PASSWORD_PROVIDERS=smtp

# 会议邀请邮件发送渠道
EMAIL_SCENE_MEETING_INVITE_PROVIDERS=wecom,smtp

# AI 任务通知邮件发送渠道
EMAIL_SCENE_AI_TASK_PROVIDERS=wecom

# ============================================================
# 短信配置
# ============================================================

# 是否启用短信功能
# true: 可以发送短信
# false: 禁用短信
SMS_ENABLED=false

# ============================================================
# 短信通用配置
# ============================================================

# 默认短信发送渠道
SMS_DEFAULT_PROVIDER=aliyun

# 短信发送超时（秒）
SMS_TIMEOUT=30

# 短信每日发送上限
# 用于成本控制
SMS_DAILY_LIMIT=500

# 短信冷却时间（秒）
# 同一手机号发送间隔
# 防止短信轰炸
SMS_COOLDOWN_SECONDS=60

# 验证码有效期（秒）
# 超过此时间验证码失效
SMS_VERIFY_CODE_EXPIRE=300

# ============================================================
# 短信场景配置
# ============================================================

